<% if (typeof content !== 'undefined') { %>
<div class="hero-section">
    <div class="hero-content">
        <% if (content.image) { %>
        <div class="hero-image">
            <img src="<%= content.image %>" alt="<%= content.title %>" />
        </div>
        <% } %>
        
        <div class="hero-text">
            <h1 class="hero-title"><%= content.title %></h1>
            <% if (content.subtitle) { %>
            <p class="hero-subtitle"><%= content.subtitle %></p>
            <% } %>
            
            <% if (content.description) { %>
            <div class="hero-description">
                <%= content.description %>
            </div>
            <% } %>
            
            <% if (content.ctaText) { %>
            <div class="hero-actions">
                <a href="<%= content.ctaLink || '#donate' %>" class="hero-cta-button">
                    <%= content.ctaText %>
                </a>
            </div>
            <% } %>
        </div>
    </div>
</div>

<style>
.hero-section {
    position: relative;
    overflow: hidden;
}

.hero-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
}

.hero-image {
    text-align: center;
}

.hero-image img {
    max-width: 100%;
    height: auto;
    border-radius: 0.75rem;
    box-shadow: 0 10px 25px rgba(0,0,0,0.1);
}

.hero-text {
    text-align: left;
}

.hero-title {
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 1rem;
    color: inherit;
}

.hero-subtitle {
    font-size: 1.25rem;
    font-weight: 500;
    margin-bottom: 1.5rem;
    color: inherit;
    opacity: 0.9;
}

.hero-description {
    font-size: 1.125rem;
    line-height: 1.6;
    margin-bottom: 2rem;
    color: inherit;
    opacity: 0.8;
}

.hero-actions {
    display: flex;
    gap: 1rem;
}

.hero-cta-button {
    display: inline-block;
    background: var(--secondary-color, #10b981);
    color: white;
    padding: 1rem 2rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
}

.hero-cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
}

/* Mobile responsiveness */
@media (max-width: 768px) {
    .hero-content {
        grid-template-columns: 1fr;
        text-align: center;
        padding: 2rem 1rem;
    }
    
    .hero-title {
        font-size: 2rem;
    }
    
    .hero-subtitle {
        font-size: 1.125rem;
    }
    
    .hero-actions {
        justify-content: center;
    }
}
</style>
<% } %>