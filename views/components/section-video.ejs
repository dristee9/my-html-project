<div class="video-section" style="background: <%= settings.backgroundColor || '#ffffff' %>; color: <%= settings.textColor || '#000000' %>; padding: <%= settings.padding.top %>px <%= settings.padding.right %>px <%= settings.padding.bottom %>px <%= settings.padding.left %>px; margin: <%= settings.margin.top %>px 0 <%= settings.margin.bottom %>px 0; border-radius: <%= settings.borderRadius %>px; box-shadow: <%= settings.boxShadow || 'none' %>;">
    <div class="container">
        <% if (content.title) { %>
            <h2 style="text-align: center; margin-bottom: 1.5rem;"><%= content.title %></h2>
        <% } %>
        
        <div class="video-wrapper" style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; max-width: 100%; margin-bottom: 1rem;">
            <iframe 
                src="<%= content.url %>" 
                frameborder="0" 
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                allowfullscreen
                style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"
                <% if (typeof content.autoplay !== 'undefined' && content.autoplay) { %>autoplay<% } %>
                <% if (typeof content.controls === 'undefined' || content.controls) { %>controls<% } %>
                <% if (typeof content.loop !== 'undefined' && content.loop) { %>loop<% } %>
            ></iframe>
        </div>
        
        <% if (content.caption) { %>
            <p class="video-caption" style="text-align: center; color: #6b7280; font-size: 0.875rem;"><%= content.caption %></p>
        <% } %>
    </div>
</div>
