<% layout('layouts/main') -%>
<% title = 'FundMyIdea BD - Student Crowdfunding Platform' -%>

<!-- Hero Section -->
<section class="landing-hero">
    <div class="hero-content">
        <h1 class="heading-1">Empower Student Innovation</h1>
        <p class="hero-subtitle">FundMyIdea BD connects passionate students with supporters to bring groundbreaking ideas to life. Join our community of innovators and changemakers today.</p>
        
        <!-- Search Bar -->
        <form action="/campaigns/search" method="GET" class="search-form" style="max-width: 600px; margin: 2rem auto; display: flex; gap: 0.5rem;">
            <input 
                type="text" 
                name="q" 
                placeholder="Search campaigns..." 
                class="form-control" 
                style="flex: 1; padding: 0.75rem 1rem; border: 2px solid var(--gray-300); border-radius: var(--border-radius-lg); font-size: 1rem;"
            >
            <button type="submit" class="btn btn--primary" style="padding: 0.75rem 2rem;">Search</button>
        </form>
        
        <div class="hero-actions">
            <% if (typeof user !== 'undefined' && user) { %>
                <a href="/builder/create" class="btn btn--primary">Start Your Campaign</a>
                <a href="/campaigns" class="btn btn--secondary">Browse Projects</a>
            <% } else { %>
                <a href="/register" class="btn btn--primary">Get Started</a>
                <a href="/campaigns" class="btn btn--secondary">Explore Campaigns</a>
            <% } %>
        </div>

        <div class="stats-overview">
            <div class="stat-card">
                <div class="stat-value"><%= stats.activeCampaigns %>+</div>
                <div class="stat-label">Active Campaigns</div>
            </div>
            <div class="stat-card">
                <div class="stat-value"><%=(stats.totalRaised / 1000).toFixed(1)%>K+</div>
                <div class="stat-label">BDT Raised</div>
            </div>
            <div class="stat-card">
                <div class="stat-value"><%= stats.universities %>+</div>
                <div class="stat-label">Universities</div>
            </div>
        </div>
    </div>
</section>

<!-- Recommended Campaigns (For Logged-in Users) -->
<% if (typeof recommendedCampaigns !== 'undefined' && recommendedCampaigns.length > 0) { %>
<section class="page-section">
    <div class="section-header">
        <h2 class="heading-2">Recommended For You</h2>
        <a href="/campaigns" class="view-all-link">View All →</a>
    </div>
    <div class="campaign-grid">
        <% recommendedCampaigns.forEach(campaign => { %>
            <div class="campaign-card">
                <a href="/campaigns/<%= campaign._id %>">
                    <img src="<%= campaign.imageUrl || 'https://placehold.co/400x200/e5e7eb/1f2937?text=' + encodeURIComponent(campaign.title.substring(0, 20).replace(/\s+/g, '+')) %>", alt="<%= campaign.title %>" class="campaign-image">
                    <div class="campaign-content">
                        <h3 class="heading-3"><%= campaign.title %></h3>
                        <p class="campaign-description"><%= campaign.description.substring(0, 100) %><%= campaign.description.length > 100 ? '...' : '' %></p>
                        <div class="campaign-meta">
                            <span class="campaign-category"><%= campaign.category %></span>
                            <span class="campaign-creator">by <%= campaign.creator?.username || 'Unknown' %></span>
                        </div>
                        <div class="campaign-stats">
                            <div class="funding-progress">
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: <%= campaign.fundingPercentage %>%"></div>
                                </div>
                                <div class="funding-amount">
                                    <span><%= campaign.currentFunding %> BDT</span>
                                    <span>of <%= campaign.fundingGoal %> BDT</span>
                                </div>
                            </div>
                            <div class="days-left"><%= campaign.daysLeftText %></div>
                        </div>
                    </div>
                </a>
            </div>
        <% }) %>
    </div>
</section>
<% } %>

