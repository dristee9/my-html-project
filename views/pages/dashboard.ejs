<% layout("layouts/main") -%>
<% title = 'Dashboard - FundMyIdea BD' -%>

<div class="dashboard-header">
    <h1 class="heading-1">Welcome back, <%= user.username %>!</h1>
    <p class="dashboard-subtitle">Manage your campaigns and track your progress</p>
</div>

<!-- Statistics Overview -->
<div class="dashboard-stats">
    <div class="stat-box">
        <div class="stat-number stat-blue"><%= typeof userStats !== 'undefined' ? userStats.campaignsCount : 0 %></div>
        <div class="stat-text">Active Campaigns</div>
    </div>
    <div class="stat-box">
        <div class="stat-number stat-green"><%= typeof userStats !== 'undefined' ? userStats.totalRaised : 0 %> BDT</div>
        <div class="stat-text">Total Funds Raised</div>
    </div>
    <div class="stat-box">
        <div class="stat-number stat-purple"><%= typeof userStats !== 'undefined' ? userStats.donationsCount : 0 %></div>
        <div class="stat-text">Total Donations</div>
    </div>
</div>

<!-- Quick Actions Section -->
<section class="quick-actions-section mb-8">
    <h2 class="heading-2 text-lg font-semibold mb-4">Quick Actions</h2>
    <div class="flex gap-4 flex-wrap">
        <a href="/builder/create" class="btn btn--primary inline-flex items-center gap-2">
            <span class="text-xl">➕</span>
            Create New Campaign
        </a>
        <a href="/dashboard/my-donations" class="btn btn--secondary inline-flex items-center gap-2">
            <span class="text-xl">💰</span>
            View All Donations
        </a>
        <a href="/dashboard/profile" class="btn btn--secondary inline-flex items-center gap-2">
            <span class="text-xl">👤</span>
            Edit Profile
        </a>
    </div>
</section>

<!-- Expiring Soon Alert -->
<% if (typeof expiringSoon !== 'undefined' && expiringSoon.length > 0) { %>
<section class="expiring-alerts-section mb-8">
    <h2 class="heading-2 text-lg font-semibold mb-4 text-error">⚠️ Campaigns Expiring Soon</h2>
    <div class="grid grid-cols-1 md-grid-cols-2 gap-4">
        <% expiringSoon.forEach(campaign => { 
            const daysLeft = Math.ceil((campaign.deadline - new Date()) / (1000 * 60 * 60 * 24));
        %>
        <div class="bg-error-light border-l-4 border-error p-4 rounded-lg">
            <div class="flex justify-between items-start">
                <div>
                    <h3 class="font-semibold text-gray-800"><%= campaign.title %></h3>
                    <p class="text-sm text-gray-600 mt-1">
                        <%= campaign.currentFunding %> BDT raised of <%= campaign.fundingGoal %> BDT
                    </p>
                </div>
                <span class="badge-active bg-accent-red text-white px-3 py-1 rounded-full text-xs font-semibold">
                    <%= daysLeft === 0 ? 'Ends Today!' : daysLeft === 1 ? '1 Day Left' : daysLeft + ' Days Left' %>
                </span>
            </div>
            <div class="mt-3 flex gap-2">
                <a href="/campaigns/<%= campaign._id %>/edit" class="text-sm btn btn--primary py-1 px-3">Edit Campaign</a>
                <a href="/campaigns/<%= campaign._id %>" class="text-sm btn btn--secondary py-1 px-3">View</a>
            </div>
        </div>
        <% }) %>
    </div>
</section>
<% } %>

<!-- My Campaigns Section -->
<section class="page-section">
    <h2 class="heading-2">My Active Campaigns</h2>
    <div class="campaign-grid">
        <% if (typeof campaigns !== 'undefined' && campaigns.length > 0) { %>
            <% campaigns.forEach(campaign => { %>
            <div class="campaign-card">
                <img src="<%= campaign.imageUrl || 'https://placehold.co/400x200/e5e7eb/1f2937?text=' + encodeURIComponent(campaign.title.substring(0, 20).replace(/\s+/g, '+')) %>", alt="<%= campaign.title %>" class="campaign-image">
                <div class="campaign-details">
                    <div class="campaign-header">
                        <span class="status-badge badge-active">Active • <%= campaign.daysLeftText %></span>
                        <span class="status-badge badge-category"><%= campaign.category %></span>
                    </div>
                    <h3 class="campaign-name"><%= campaign.title %></h3>
                    <div class="progress-container">
                        <div class="progress-track">
                            <div class="progress-fill" style="width: <%= campaign.fundingPercentage %>%"></div>
                        </div>
                        <div class="progress-info">
                            <span><%= campaign.currentFunding %> BDT raised</span>
                            <span>of <%= campaign.fundingGoal %> BDT goal</span>
                        </div>
                    </div>
                    <div class="campaign-footer">
                        <span class="time-remaining"><%= campaign.daysLeftText %></span>
                        <div class="flex gap-4">
                            <a href="/campaigns/<%= campaign._id %>" class="view-button">View</a>
                            <a href="/campaigns/<%= campaign._id %>/edit" class="btn btn--secondary text-sm px-4 py-2">Edit</a>
                        </div>
                    </div>
                </div>
            </div>
            <% }) %>
        <% } else { %>
            <div class="empty-state">
                <h3 class="text-xl text-gray-600 mb-4">No campaigns yet</h3>
                <p class="text-gray-500 mb-6">Start your first campaign to bring your ideas to life!</p>
                <a href="/builder/create" class="btn btn--primary">Create Your First Campaign</a>
            </div>
        <% } %>
    </div>
</section>

<!-- Recent Donations -->
<section class="page-section">
    <h2 class="heading-2">Recent Donations Received</h2>
    <div class="table-container">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Campaign</th>
                    <th>Donor</th>
                    <th>Amount</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td colspan="4" class="empty-state">
                        No donations received yet
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</section>

<!-- Recent Activity Feed -->
<section class="page-section">
    <h2 class="heading-2">Recent Activity</h2>
    <% if (typeof recentActivities !== 'undefined' && recentActivities.length > 0) { %>
    <div class="activity-feed bg-white rounded-xl shadow-lg p-6">
        <div class="space-y-4">
            <% recentActivities.forEach(activity => { %>
            <div class="activity-item flex items-start gap-4 pb-4 border-b border-gray-200 last:border-b-0">
                <div class="text-2xl"><%= activity.icon %></div>
                <div class="flex-1">
                    <p class="font-medium text-gray-800">
                        <% if (activity.type === 'donation_received') { %>
                            💰 Received <%= activity.amount %> BDT donation from <%= activity.donorName %> for "<%= activity.campaignTitle %>"
                        <% } else if (activity.type === 'campaign_completed') { %>
                            ✅ <%= activity.message %>: "<%= activity.campaignTitle %>"
                        <% } else if (activity.type === 'campaign_expired') { %>
                            ⏰ <%= activity.message %>: "<%= activity.campaignTitle %>"
                        <% } %>
                    </p>
                    <p class="text-sm text-gray-500 mt-1">
                        <%= new Date(activity.date).toLocaleDateString('en-US', { 
                            month: 'short', 
                            day: 'numeric', 
                            year: 'numeric',
                            hour: '2-digit',
                            minute: '2-digit'
                        }) %>
                    </p>
                </div>
            </div>
            <% }) %>
        </div>
    </div>
    <% } else { %>
    <div class="empty-state-box bg-white rounded-xl shadow-lg p-8">
        <p class="text-gray-500 text-lg">No recent activity to show</p>
        <p class="text-gray-400 text-sm mt-2">Your campaign activity will appear here</p>
    </div>
    <% } %>
</section>