<% layout('layouts/main') -%>
<% title = 'Verify Your Email - FundMyIdea BD' -%>

<div class="verify-container">
    <div class="verify-card">
        <div class="verify-icon"><i class="fa fa-envelope"></i></div>
        <h1 class="verify-title">Check Your Email</h1>
        
        <% if (typeof success !== 'undefined' && success) { %>
            <div class="success-banner" style="background: var(--success-light, #dcfce7); color: var(--secondary-green); padding: 1rem; border-radius: var(--border-radius-lg); margin-bottom: 1.5rem; text-align: center;">
                <%= success %>
            </div>
        <% } %>
        
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="error-banner" style="background: #fee2e2; color: #dc2626; padding: 1rem; border-radius: var(--border-radius-lg); margin-bottom: 1.5rem; text-align: center;">
                <%= error %>
            </div>
        <% } %>
        
        <p class="verify-message">
            We've sent a verification email to <strong><%= typeof email !== 'undefined' ? email : 'your email address' %></strong>.
        </p>
        
        <div class="verify-instructions">
            <h3>Next Steps:</h3>
            <ol>
                <li>Check your email inbox</li>
                <li>Click the verification link in the email</li>
                <li>You'll be automatically logged in after verification</li>
            </ol>
        </div>
        
        <div class="verify-tips">
            <p><strong><i class="fa fa-lightbulb-o"></i> Tips:</strong></p>
            <ul>
                <li>Check your spam/junk folder if you don't see the email</li>
                <li>The verification link will expire after 24 hours</li>
                <li>Don't share the verification link with anyone</li>
            </ul>
        </div>
        
        <div class="verify-actions">
            <a href="/resend-verification" class="btn btn--primary btn--full" style="display: inline-block; margin-bottom: 1rem;">
                <i class="fa fa-refresh"></i> Resend Verification Email
            </a>
            
            <div style="margin-top: 1rem;">
                <p style="color: var(--gray-600); font-size: 0.875rem;">
                    Already verified? <a href="/login" class="form-link">Login here</a>
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    .verify-container {
        max-width: 600px;
        margin: 3rem auto;
        padding: 2rem 1rem;
    }
    
    .verify-card {
        background: white;
        border-radius: var(--border-radius-xl);
        box-shadow: var(--shadow-lg);
        padding: 3rem 2rem;
        text-align: center;
    }
    
    .verify-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
    }
    
    .verify-title {
        font-size: 2rem;
        font-weight: 700;
        color: var(--primary-blue);
        margin-bottom: 1rem;
    }
    
    .verify-message {
        font-size: 1.125rem;
        color: var(--gray-700);
        margin-bottom: 2rem;
        line-height: 1.6;
    }
    
    .verify-instructions {
        background: var(--gray-50);
        padding: 1.5rem;
        border-radius: var(--border-radius-lg);
        margin: 2rem 0;
        text-align: left;
    }
    
    .verify-instructions h3 {
        color: var(--gray-800);
        margin-bottom: 1rem;
        font-size: 1.25rem;
    }
    
    .verify-instructions ol {
        color: var(--gray-700);
        line-height: 2;
        padding-left: 1.5rem;
    }
    
    .verify-tips {
        background: #fef3c7;
        border-left: 4px solid #f59e0b;
        padding: 1.5rem;
        border-radius: var(--border-radius-md);
        margin: 2rem 0;
        text-align: left;
    }
    
    .verify-tips p {
        color: #92400e;
        font-weight: 600;
        margin-bottom: 0.5rem;
    }
    
    .verify-tips ul {
        color: #78350f;
        line-height: 1.8;
        padding-left: 1.5rem;
    }
    
    .verify-actions {
        margin-top: 2rem;
    }
    
    @media (max-width: 640px) {
        .verify-card {
            padding: 2rem 1rem;
        }
        
        .verify-icon {
            font-size: 3rem;
        }
        
        .verify-title {
            font-size: 1.5rem;
        }
    }
</style>
