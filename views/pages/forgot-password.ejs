<% layout('layouts/main') -%>
<% title = 'Forgot Password - FundMyIdea BD' -%>

<form class="auth-form" method="POST" action="/forgot-password">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <h2 class="heading-2">Reset Your Password</h2>
    
    <% if (typeof error !== 'undefined' && error) { %>
        <div class="error-banner mb-4">
            <%= error %>
        </div>
    <% } %>
    
    <p class="text-muted mb-6">
        Enter your email address and we'll send you a link to reset your password.
    </p>
    
    <div class="form-group">
        <label class="form-label">Email Address</label>
        <input 
            type="email" 
            name="email"
            class="form-control" 
            placeholder="Enter your email" 
            required>
    </div>
    
    <button type="submit" class="submit-button">Send Reset Link</button>
    
    <div class="form-footer">
        Remember your password? <a href="/login" class="form-link">Login here</a>
    </div>
</form>