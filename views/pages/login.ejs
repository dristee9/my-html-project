<% layout('layouts/main') -%>
<% title = 'Login - FundMyIdea BD' -%>

<form class="form-card auth-form" method="POST" action="/login">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="hidden" name="next" value="<%= typeof formData !== 'undefined' && formData.next ? formData.next : '' %>">
    <h2 class="heading-2 auth-form-title">Login to FundMyIdea BD</h2>
    
    <% if (typeof error !== 'undefined' && error) { %>
        <div class="error-banner mb-4">
            <%= error %>
        </div>
    <% } %>
    
    <div class="form-group">
        <label class="form-label">Email Address</label>
        <input 
            type="email" 
            name="email"
            class="form-control" 
            placeholder="Enter your email" 
            value="<%= typeof formData !== 'undefined' && formData.email ? formData.email : '' %>"
            required>
    </div>
    
    <div class="form-group">
        <label class="form-label">Password</label>
        <input 
            type="password" 
            name="password"
            class="form-control" 
            placeholder="Enter your password" 
            required>
    </div>
    
    <button type="submit" class="btn btn--primary btn--full">Login to Account</button>
    
    <div class="form-footer">
        Don't have an account? <a href="/register" class="form-link">Register here</a>
    </div>
</form>