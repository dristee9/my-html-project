<% layout('layouts/main') -%>
<% title = 'Login - FundMyIdea BD' -%>

<form class="auth-form" method="POST" action="/login">
    <h2 class="form-title">Login to FundMyIdea BD</h2>
    
    <% if (typeof error !== 'undefined' && error) { %>
        <div style="background-color: #fee2e2; color: #dc2626; padding: 1rem; border-radius: 0.5rem; margin-bottom: 1rem; border: 1px solid #fecaca;">
            <%= error %>
        </div>
    <% } %>
    
    <div class="form-group">
        <label class="form-label">Email Address</label>
        <input 
            type="email" 
            name="email"
            class="form-control" 
            placeholder="Enter your email" 
            value="<%= typeof formData !== 'undefined' && formData.email ? formData.email : '' %>"
            required>
    </div>
    
    <div class="form-group">
        <label class="form-label">Password</label>
        <input 
            type="password" 
            name="password"
            class="form-control" 
            placeholder="Enter your password" 
            required>
    </div>
    
    <button type="submit" class="submit-button">Login to Account</button>
    
    <div class="form-footer">
        Don't have an account? <a href="/register" class="form-link">Register here</a>
    </div>
</form>