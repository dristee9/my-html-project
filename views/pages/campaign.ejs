<% layout("layouts/main") -%>
<% title = 'Campaign Details - FundMyIdea BD' -%>

<div class="campaign-detail-page">
    <div class="campaign-header-image">
        <img src="https://via.placeholder.com/1200x400/f3f4f6/1f2937?text=Eco+Friendly+Waste+Management+App" alt="Campaign Image" class="campaign-main-image">
    </div>
    
    <div class="campaign-content">
        <div class="campaign-info">
            <div class="campaign-header">
                <span class="status-badge badge-active">Active • 15 days left</span>
                <span class="status-badge badge-category">Technology</span>
            </div>
            
            <h1 class="campaign-title">Eco-Friendly Waste Management Mobile Application</h1>
            <p class="campaign-author-detail">by Sarah Ahmed, BRAC University Computer Science Student</p>
            
            <div class="funding-summary">
                <div class="progress-container">
                    <div class="progress-track">
                        <div class="progress-fill" style="width: 65%"></div>
                    </div>
                </div>
                <div class="funding-amount">
                    <span>32,500 BDT</span>
                    <span>raised of 50,000 BDT goal</span>
                </div>
                <div class="supporters-count">Supported by 47 generous backers</div>
            </div>
        </div>

        <div class="campaign-description">
            <h2 class="section-subtitle">About this Campaign</h2>
            <div class="description-content">
                <p>Our innovative mobile application aims to revolutionize waste management in urban Bangladesh by connecting citizens with local recycling centers and waste collection services. The app will feature real-time tracking of waste collection trucks, educational content about proper waste segregation, and a reward system for active participation.</p>
                
                <p>Built using Flutter for cross-platform compatibility, the app will integrate with Google Maps API for location services and Firebase for real-time data synchronization. Our target users are environmentally conscious citizens aged 18-45 in Dhaka city.</p>
                
                <p>The funds raised will be used for:</p>
                <ul class="funding-breakdown">
                    <li>App development and testing: 40%</li>
                    <li>Server infrastructure and hosting: 25%</li>
                    <li>Marketing and user acquisition: 20%</li>
                    <li>Legal compliance and permits: 10%</li>
                    <li>Contingency fund: 5%</li>
                </ul>
            </div>
        </div>

        <div class="donation-section">
            <h2 class="section-subtitle">Support this Project</h2>
            <form class="donation-form" method="POST" action="/campaigns/donate">
                <div class="form-group">
                    <label class="form-label">Donation Amount (BDT)</label>
                    <input type="number" name="amount" class="form-control" placeholder="Enter amount" min="100" required>
                </div>
                
                <div class="form-group">
                    <label class="form-label">Your Message (Optional)</label>
                    <textarea name="message" class="form-control" rows="4" placeholder="Leave an encouraging message for the creator..."></textarea>
                </div>
                
                <div class="form-group">
                    <label class="form-label">bKash Number</label>
                    <input type="text" name="bkashNumber" class="form-control" placeholder="Enter your bKash number" required>
                </div>
                
                <button type="submit" class="submit-button donation-button">Donate Now via bKash</button>
            </form>
        </div>
    </div>
</div>