<% layout('layouts/main') -%>
<% title = typeof campaign !== 'undefined' && campaign ? 'Donate to ' + campaign.title + ' - FundMyIdea BD' : 'Donate - FundMyIdea BD' -%>

<div class="donate-page">
    <% if (typeof campaign !== 'undefined' && campaign) { %>
        <%- include('../partials/breadcrumbs', {
            breadcrumbs: [
                { label: 'Campaigns', href: '/campaigns' },
                { label: campaign.title, href: '/campaigns/' + campaign._id },
                { label: 'Donate' }
            ]
        }) %>
        
        <!-- Campaign Header Section -->
        <div class="donate-header">
            <div class="campaign-preview">
                <img src="<%= campaign.imageUrl || 'https://placehold.co/800x400/e5e7eb/1f2937?text=' + encodeURIComponent(campaign.title.substring(0, 30).replace(/\s+/g, '+')) %>", 
                     alt="<%= campaign.title %>" 
                     class="campaign-preview-image">
                <div class="campaign-preview-info">
                    <h1 class="campaign-preview-title"><%= campaign.title %></h1>
                    <p class="campaign-preview-creator">by <%= campaign.creator.username %>, <%= campaign.creator.university %> Student</p>
                    <div class="campaign-preview-stats">
                        <span class="stat-item"><%= campaign.currentFunding %> BDT raised</span>
                        <span class="stat-item"><%= campaign.fundingPercentage %>% funded</span>
                        <span class="stat-item"><%= campaign.backers.length %> backers</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="donate-content">
            <div class="donate-form-section">
                <div class="form-container">
                    <h2 class="heading-2">Make Your Donation</h2>
                    <p class="form-subtitle">Support this student's innovative idea with a secure donation via bKash</p>
                    
                    <% if (typeof error !== 'undefined' && error) { %>
                        <div class="error-message">
                            <i class="error-icon">⚠️</i>
                            <span><%= error %></span>
                        </div>
                    <% } %>

                    <% if (typeof success !== 'undefined' && success) { %>
                        <div class="success-message">
                            <i class="success-icon">✅</i>
                            <span><%= success %></span>
                        </div>
                    <% } %>

                    <form class="donation-form js-form" method="POST" action="/campaigns/<%= campaign._id %>/donate">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <!-- Donation Amount Selection -->
                        <div class="form-section">
                            <h3 class="heading-3">Choose Your Donation Amount</h3>
                            <div class="amount-options">
                                <button type="button" class="amount-option" data-amount="500">500 BDT</button>
                                <button type="button" class="amount-option" data-amount="1000">1000 BDT</button>
                                <button type="button" class="amount-option" data-amount="2000">2000 BDT</button>
                                <button type="button" class="amount-option" data-amount="5000">5000 BDT</button>
                                <button type="button" class="amount-option custom-amount" data-amount="custom">Custom Amount</button>
                            </div>
                            
                            <div class="form-group">
                                <label class="form-label">Donation Amount (BDT)</label>
                                <div class="amount-input-container">
                                    <span class="currency-symbol">৳</span>
                                    <input type="number" 
                                           name="amount" 
                                           id="donationAmount" 
                                           class="form-control amount-input" 
                                           placeholder="Enter amount (minimum 100 BDT)" 
                                           min="100" 
                                           required>
                                </div>
                                <div class="amount-hint">Minimum donation: 100 BDT</div>
                            </div>
                        </div>

                        <!-- Donor Information -->
                        <div class="form-section">
                            <h3 class="heading-3">Your Information</h3>
                            
                            <div class="form-group">
                                <label class="form-label">bKash Number *</label>
                                <input type="tel" 
                                       name="bkashNumber" 
                                       class="form-control" 
                                       placeholder="Enter your bKash mobile number" 
                                       pattern="[0-9]{11}" 
                                       required>
                                <div class="field-hint">We'll use this to process your payment via bKash</div>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Your Message (Optional)</label>
                                <textarea name="message" 
                                          id="donationMessage"
                                          class="form-control" 
                                          rows="4" 
                                          placeholder="Leave an encouraging message for the campaign creator..."></textarea>
                                <div class="field-hint">Your message will be visible to the campaign creator and other supporters</div>
                            </div>
                        </div>

                        <!-- Reward Tiers Section -->
                        <% if (campaign.rewards && campaign.rewards.length > 0) { %>
                        <div class="form-section" style="margin-top: 2rem;">
                            <h3 class="heading-3">🎁 Choose a Reward Tier (Optional)</h3>
                            <p style="color: var(--gray-600); font-size: 0.875rem; margin-bottom: 1rem;">Select a reward tier that matches your donation amount</p>
                            
                            <div class="reward-tiers-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem;">
                                <% campaign.rewards.slice().sort((a, b) => a.minAmount - b.minAmount).forEach(reward => { 
                                    const isAvailable = !reward.limitedQuantity || reward.claimedCount < reward.limitedQuantity;
                                    const remaining = reward.limitedQuantity ? reward.limitedQuantity - reward.claimedCount : '∞';
                                %>
                                    <label class="reward-tier-card" style="border: 2px solid var(--gray-200); border-radius: var(--border-radius-lg); padding: 1rem; cursor: pointer; transition: all var(--transition-fast); position: relative; <%= !isAvailable ? 'opacity: 0.5; cursor: not-allowed;' : '' %>" onclick="<%= !isAvailable ? 'return false;' : '' %>">
                                        <input type="radio" name="selectedRewardId" value="<%= reward._id %>" style="position: absolute; top: 1rem; right: 1rem; opacity: 0;">
                                        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem;">
                                            <div style="font-size: 2rem;"><%= isAvailable ? '🎁' : '❌' %></div>
                                            <div style="flex: 1;">
                                                <div style="font-weight: 700; color: var(--gray-800); font-size: 1rem;"><%= reward.title %></div>
                                                <div style="color: var(--secondary-green); font-weight: 700; font-size: 0.875rem;">${<%= reward.minAmount.toLocaleString() %> BDT+</div>
                                            </div>
                                        </div>
                                        <div style="color: var(--gray-600); font-size: 0.875rem; margin-bottom: 0.75rem; line-height: 1.4;"><%= reward.description %></div>
                                        <div style="display: flex; justify-content: space-between; align-items: center; font-size: 0.75rem; color: var(--gray-500);">
                                            <% if (reward.deliveryDate) { %>
                                                <span>📅 Delivers <%= new Date(reward.deliveryDate).toLocaleDateString() %></span>
                                            <% } %>
                                            <% if (reward.limitedQuantity) { %>
                                                <span style="background: <%= remaining < 10 ? '#fee2e2' : '#f0fdf4' %>; color: <%= remaining < 10 ? '#dc2626' : '#16a34a' %>; padding: 0.25rem 0.5rem; border-radius: var(--border-radius-full); font-weight: 600;">
                                                    <%= remaining %> left
                                                </span>
                                            <% } %>
                                        </div>
                                    </label>
                                <% }); %>
                            </div>
                        </div>
                        <% } %>

                        <!-- Payment Instructions -->
                        <div class="payment-instructions">
                            <h3 class="heading-3">How It Works</h3>
                            <div class="instructions-content">
                                <div class="instruction-step">
                                    <span class="step-number">1</span>
                                    <div class="step-content">
                                        <h4>Enter donation amount</h4>
                                        <p>Choose a preset amount or enter your custom donation</p>
                                    </div>
                                </div>
                                <div class="instruction-step">
                                    <span class="step-number">2</span>
                                    <div class="step-content">
                                        <h4>Provide bKash number</h4>
                                        <p>We'll use this to process your payment securely</p>
                                    </div>
                                </div>
                                <div class="instruction-step">
                                    <span class="step-number">3</span>
                                    <div class="step-content">
                                        <h4>Submit and support</h4>
                                        <p>Your contribution will appear on the campaign page once verified</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Submit Button -->
                        <div class="form-actions">
                            <button type="submit" class="btn btn--success-gradient">
                                <span class="button-text">Process Donation</span>
                                <span class="button-amount" id="buttonAmount"></span>
                            </button>
                            
                            <!-- OR Divider -->
                            <div class="or-divider" style="display: flex; align-items: center; margin: 1.5rem 0; color: var(--gray-500);">
                                <div style="flex: 1; height: 1px; background: var(--gray-300);"></div>
                                <span style="padding: 0 1rem; font-size: 0.875rem;">OR PAY WITH</span>
                                <div style="flex: 1; height: 1px; background: var(--gray-300);"></div>
                            </div>
                            
                            <!-- bKash Payment Button -->
                            <button type="button" class="bkash-payment-button" id="bkashPaymentBtn" style="width: 100%; padding: 1rem; background: #e2136e; color: white; border: none; border-radius: var(--border-radius-md); font-size: 1rem; font-weight: 600; cursor: pointer; transition: all var(--transition-fast); display: flex; align-items: center; justify-content: center; gap: 0.5rem;">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.31-8.86c-1.77-.45-2.34-.94-2.34-1.67 0-.84.79-1.43 2.1-1.43 1.38 0 1.9.66 1.94 1.64h1.71c-.05-1.34-.87-2.57-2.49-2.97V5H10.9v1.69c-1.51.32-2.72 1.3-2.72 2.81 0 1.79 1.49 2.69 3.66 3.21 1.95.46 2.34 1.15 2.34 1.87 0 .53-.39 1.39-2.1 1.39-1.6 0-2.23-.72-2.32-1.64H8.04c.1 1.7 1.36 2.66 2.86 2.97V19h2.34v-1.67c1.52-.29 2.72-1.16 2.73-2.77-.01-2.2-1.9-2.96-3.66-3.42z"/>
                                </svg>
                                <span>Pay with bKash</span>
                            </button>
                            
                            <div class="security-note" style="margin-top: 1rem;">
                                <i class="security-icon">🔒</i>
                                <span>Your donation information is secure and will be verified before processing</span>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Campaign Progress Sidebar -->
            <div class="donate-sidebar">
                <div class="progress-widget">
                    <h3 class="widget-title">Campaign Progress</h3>
                    <div class="progress-container">
                        <div class="progress-bar">
                            <div class="progress-fill" data-width="<%= campaign.fundingPercentage %>"></div>
                        </div>
                        <div class="progress-stats">
                            <div class="stat">
                                <span class="stat-value"><%= campaign.currentFunding %></span>
                                <span class="stat-label">BDT Raised</span>
                            </div>
                            <div class="stat">
                                <span class="stat-value"><%= campaign.fundingGoal %></span>
                                <span class="stat-label">Goal</span>
                            </div>
                            <div class="stat">
                                <span class="stat-value"><%= typeof campaign.daysRemaining !== 'undefined' ? campaign.daysRemaining : '-' %></span>
                                <span class="stat-label"><%= typeof campaign.daysRemaining !== 'undefined' && campaign.daysRemaining === 1 ? 'Day' : 'Days' %> Left</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="creator-widget">
                    <h3 class="widget-title">Meet the Creator</h3>
                    <div class="creator-info">
                        <div class="creator-avatar">
                            <% if (campaign.creator.profileImage) { %>
                                <img src="<%= campaign.creator.profileImage %>" alt="<%= campaign.creator.username %>" class="avatar-image">
                            <% } else { %>
                                <div class="avatar-placeholder">
                                    <%= campaign.creator.username.charAt(0).toUpperCase() %>
                                </div>
                            <% } %>
                        </div>
                        <div class="creator-details">
                            <h4 class="creator-name"><%= campaign.creator.username %></h4>
                            <p class="creator-university"><%= campaign.creator.university %></p>
                        </div>
                    </div>
                    <p class="creator-bio">A passionate student bringing innovative ideas to life with community support.</p>
                </div>

                <div class="recent-supporters">
                    <h3 class="widget-title">Recent Supporters</h3>
                    <% if (campaign.backers.length > 0) { %>
                        <div class="supporters-list">
                            <% campaign.backers.slice(-3).reverse().forEach(backer => { %>
                                <div class="supporter-item">
                                    <div class="supporter-info">
                                        <span class="supporter-name"><%= backer.user.username || 'Anonymous Supporter' %></span>
                                        <span class="supporter-amount"><%= backer.amount %> BDT</span>
                                    </div>
                                    <% if (backer.message) { %>
                                        <p class="supporter-message"><%= backer.message.substring(0, 60) + (backer.message.length > 60 ? '...' : '') %></p>
                                    <% } %>
                                </div>
                            <% }); %>
                        </div>
                    <% } else { %>
                        <p class="no-supporters">Be the first to support this campaign!</p>
                    <% } %>
                </div>
            </div>
        </div>
    <% } else { %>
        <div class="error-page">
            <h1>Campaign Not Found</h1>
            <p>The campaign you're trying to support doesn't exist or has been removed.</p>
            <a href="/campaigns" class="btn btn--primary">Browse Other Campaigns</a>
        </div>
    <% } %>
</div>

<script>
// Handle amount selection buttons
document.querySelectorAll('.amount-option').forEach(button => {
    button.addEventListener('click', function() {
        // Remove active class from all buttons
        document.querySelectorAll('.amount-option').forEach(btn => {
            btn.classList.remove('active');
        });
        
        // Add active class to clicked button
        this.classList.add('active');
        
        // Set the amount value
        const amount = this.dataset.amount;
        const amountInput = document.getElementById('donationAmount');
        
        if (amount === 'custom') {
            amountInput.focus();
        } else {
            amountInput.value = amount;
            updateButtonAmount(amount);
        }
    });
});

// Update button amount display
function updateButtonAmount(amount) {
    const buttonAmount = document.getElementById('buttonAmount');
    buttonAmount.textContent = `৳${amount}`;
}

// Update amount when typing
document.getElementById('donationAmount').addEventListener('input', function() {
    updateButtonAmount(this.value || 0);
    
    // Remove active class from preset buttons when typing custom amount
    document.querySelectorAll('.amount-option:not(.custom-amount)').forEach(btn => {
        btn.classList.remove('active');
    });
    
    // Auto-highlight best matching reward tier
    highlightMatchingReward(parseInt(this.value) || 0);
});

// Highlight matching reward based on amount
function highlightMatchingReward(amount) {
    const rewardCards = document.querySelectorAll('.reward-tier-card');
    rewardCards.forEach(card => {
        const minAmountText = card.querySelector('[style*="color: var(--secondary-green)"]').textContent;
        const minAmount = parseInt(minAmountText.replace(/[^0-9]/g, ''));
        
        if (amount >= minAmount) {
            card.style.borderColor = 'var(--secondary-green)';
            card.style.background = '#f0fdf4';
        } else {
            card.style.borderColor = 'var(--gray-200)';
            card.style.background = 'white';
        }
    });
}

// Reward tier selection
document.querySelectorAll('.reward-tier-card').forEach(card => {
    card.addEventListener('click', function() {
        // Deselect other cards
        document.querySelectorAll('.reward-tier-card').forEach(c => {
            c.style.borderColor = 'var(--gray-200)';
            c.style.background = 'white';
        });
        
        // Select this card
        this.style.borderColor = 'var(--primary-blue)';
        this.style.background = '#eff6ff';
        this.querySelector('input[type="radio"]').checked = true;
    });
});

// Form validation
document.querySelector('.donation-form').addEventListener('submit', function(e) {
    const amount = parseInt(document.getElementById('donationAmount').value);
    const bkashNumber = document.querySelector('input[name="bkashNumber"]').value;
    
    if (amount < 100) {
        e.preventDefault();
        alert('Minimum donation amount is 100 BDT');
        return;
    }
    
    if (!bkashNumber.match(/^[0-9]{11}$/)) {
        e.preventDefault();
        alert('Please enter a valid 11-digit bKash number');
        return;
    }
    
    // Show loading state
    const submitButton = document.querySelector('.donation-submit-button');
    submitButton.disabled = true;
    submitButton.innerHTML = '<span class="button-text">Processing...</span>';
});

// Handle bKash payment button
document.getElementById('bkashPaymentBtn').addEventListener('click', async function() {
    const amount = document.getElementById('donationAmount').value;
    const message = document.getElementById('donationMessage').value || '';
    
    // Validate amount
    const donationAmount = parseInt(amount);
    if (!amount || donationAmount < 100) {
        alert('Please enter a valid donation amount (minimum 100 BDT)');
        return;
    }
    
    // Get CSRF token
    const csrfToken = document.querySelector('[name="_csrf"]').value;
    
    try {
        // Disable button and show loading state
        const bkashBtn = document.getElementById('bkashPaymentBtn');
        bkashBtn.disabled = true;
        bkashBtn.innerHTML = '<span>Initiating Payment...</span>';
        bkashBtn.style.opacity = '0.7';
        
        // Call backend to initiate bKash payment with CSRF token
        const response = await fetch(`/campaigns/${'<%= campaign._id %>'}/bkash/initiate`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ amount: donationAmount, message, _csrf: csrfToken })
        });
        
        const result = await response.json();
        
        if (result.success && result.bkashURL) {
            // Redirect user to bKash payment page
            window.location.href = result.bkashURL;
        } else {
            throw new Error(result.error || 'Failed to initiate payment');
        }
    } catch (error) {
        console.error('bKash payment error:', error);
        alert('Failed to initiate bKash payment. Please try again or use manual payment.');
        
        // Re-enable button
        const bkashBtn = document.getElementById('bkashPaymentBtn');
        bkashBtn.disabled = false;
        bkashBtn.innerHTML = `
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.31-8.86c-1.77-.45-2.34-.94-2.34-1.67 0-.84.79-1.43 2.1-1.43 1.38 0 1.9.66 1.94 1.64h1.71c-.05-1.34-.87-2.57-2.49-2.97V5H10.9v1.69c-1.51.32-2.72 1.3-2.72 2.81 0 1.79 1.49 2.69 3.66 3.21 1.95.46 2.34 1.15 2.34 1.87 0 .53-.39 1.39-2.1 1.39-1.6 0-2.23-.72-2.32-1.64H8.04c.1 1.7 1.36 2.66 2.86 2.97V19h2.34v-1.67c1.52-.29 2.72-1.16 2.73-2.77-.01-2.2-1.9-2.96-3.66-3.42z"/>
            </svg>
            <span>Pay with bKash</span>
        `;
        bkashBtn.style.opacity = '1';
    }
});
</script>