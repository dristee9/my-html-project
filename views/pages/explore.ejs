<% layout('layouts/main') -%>
<% title = 'Explore Campaigns - FundMyIdea BD' -%>

<section class="page-section">
    <% if (typeof searchQuery !== 'undefined' && searchQuery && searchQuery.trim() !== '') { %>
        <h1 class="heading-1">Search Results for: "<%= searchQuery %>"</h1>
    <% } else if (typeof searchCategory !== 'undefined' && searchCategory && searchCategory !== 'all') { %>
        <h1 class="heading-1">Browse Category: <%= searchCategory %></h1>
    <% } else { %>
        <h1 class="heading-1">Explore Student Campaigns</h1>
    <% } %>
    
    <!-- Search and Filter Bar -->
    <div class="search-filter-bar" style="background: white; padding: 2rem; border-radius: var(--border-radius-xl); box-shadow: var(--shadow-lg); margin-bottom: 2rem;">
        <form method="GET" action="/campaigns/search" class="search-filter-form">
            <div class="search-row" style="display: flex; gap: 1rem; margin-bottom: 1.5rem; flex-wrap: wrap;">
                <input type="text" name="q" class="form-control search-input" placeholder="Search campaigns..." value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>" style="flex: 1; min-width: 250px;">
                <select name="category" class="form-control" style="min-width: 180px;">
                    <option value="all">All Categories</option>
                    <option value="Technology" <%= typeof searchCategory !== 'undefined' && searchCategory === 'Technology' ? 'selected' : '' %>>Technology</option>
                    <option value="Education" <%= typeof searchCategory !== 'undefined' && searchCategory === 'Education' ? 'selected' : '' %>>Education</option>
                    <option value="Social Impact" <%= typeof searchCategory !== 'undefined' && searchCategory === 'Social Impact' ? 'selected' : '' %>>Social Impact</option>
                    <option value="Arts & Culture" <%= typeof searchCategory !== 'undefined' && searchCategory === 'Arts & Culture' ? 'selected' : '' %>>Arts & Culture</option>
                    <option value="Research" <%= typeof searchCategory !== 'undefined' && searchCategory === 'Research' ? 'selected' : '' %>>Research</option>
                    <option value="Other" <%= typeof searchCategory !== 'undefined' && searchCategory === 'Other' ? 'selected' : '' %>>Other</option>
                </select>
                <select name="sort" class="form-control" style="min-width: 180px;">
                    <option value="newest" <%= typeof sortBy !== 'undefined' && sortBy === 'newest' ? 'selected' : '' %>>Newest First</option>
                    <option value="most-funded" <%= typeof sortBy !== 'undefined' && sortBy === 'most-funded' ? 'selected' : '' %>>Most Funded</option>
                    <option value="ending-soon" <%= typeof sortBy !== 'undefined' && sortBy === 'ending-soon' ? 'selected' : '' %>>Ending Soon</option>
                </select>
                <button type="submit" class="btn btn--primary" style="padding: 0.75rem 2rem;">Search</button>
            </div>
        </form>
        
        <!-- Quick Category Filters -->
        <div class="category-filters" style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 1rem;">
            <a href="/campaigns/search?category=all&sort=<%= typeof sortBy !== 'undefined' ? sortBy : 'newest' %>" 
               class="category-tag <%= typeof searchCategory === 'undefined' || searchCategory === 'all' ? 'active' : '' %>"
               style="padding: 0.5rem 1rem; border-radius: var(--border-radius-full); text-decoration: none; font-size: 0.875rem; transition: all var(--transition-fast); <%= typeof searchCategory === 'undefined' || searchCategory === 'all' ? 'background: var(--primary-blue); color: white;' : 'background: var(--gray-100); color: var(--gray-700);' %>">
               All
            </a>
            <a href="/campaigns/search?category=Technology&sort=<%= typeof sortBy !== 'undefined' ? sortBy : 'newest' %>" 
               class="category-tag <%= typeof searchCategory !== 'undefined' && searchCategory === 'Technology' ? 'active' : '' %>"
               style="padding: 0.5rem 1rem; border-radius: var(--border-radius-full); text-decoration: none; font-size: 0.875rem; transition: all var(--transition-fast); <%= typeof searchCategory !== 'undefined' && searchCategory === 'Technology' ? 'background: var(--primary-blue); color: white;' : 'background: var(--gray-100); color: var(--gray-700);' %>">
               Technology
            </a>
            <a href="/campaigns/search?category=Education&sort=<%= typeof sortBy !== 'undefined' ? sortBy : 'newest' %>" 
               class="category-tag <%= typeof searchCategory !== 'undefined' && searchCategory === 'Education' ? 'active' : '' %>"
               style="padding: 0.5rem 1rem; border-radius: var(--border-radius-full); text-decoration: none; font-size: 0.875rem; transition: all var(--transition-fast); <%= typeof searchCategory !== 'undefined' && searchCategory === 'Education' ? 'background: var(--primary-blue); color: white;' : 'background: var(--gray-100); color: var(--gray-700);' %>">
               Education
            </a>
            <a href="/campaigns/search?category=Social Impact&sort=<%= typeof sortBy !== 'undefined' ? sortBy : 'newest' %>" 
               class="category-tag <%= typeof searchCategory !== 'undefined' && searchCategory === 'Social Impact' ? 'active' : '' %>"
               style="padding: 0.5rem 1rem; border-radius: var(--border-radius-full); text-decoration: none; font-size: 0.875rem; transition: all var(--transition-fast); <%= typeof searchCategory !== 'undefined' && searchCategory === 'Social Impact' ? 'background: var(--primary-blue); color: white;' : 'background: var(--gray-100); color: var(--gray-700);' %>">
               Social Impact
            </a>
            <a href="/campaigns/search?category=Arts & Culture&sort=<%= typeof sortBy !== 'undefined' ? sortBy : 'newest' %>" 
               class="category-tag <%= typeof searchCategory !== 'undefined' && searchCategory === 'Arts & Culture' ? 'active' : '' %>"
               style="padding: 0.5rem 1rem; border-radius: var(--border-radius-full); text-decoration: none; font-size: 0.875rem; transition: all var(--transition-fast); <%= typeof searchCategory !== 'undefined' && searchCategory === 'Arts & Culture' ? 'background: var(--primary-blue); color: white;' : 'background: var(--gray-100); color: var(--gray-700);' %>">
               Arts & Culture
            </a>
            <a href="/campaigns/search?category=Research&sort=<%= typeof sortBy !== 'undefined' ? sortBy : 'newest' %>" 
               class="category-tag <%= typeof searchCategory !== 'undefined' && searchCategory === 'Research' ? 'active' : '' %>"
               style="padding: 0.5rem 1rem; border-radius: var(--border-radius-full); text-decoration: none; font-size: 0.875rem; transition: all var(--transition-fast); <%= typeof searchCategory !== 'undefined' && searchCategory === 'Research' ? 'background: var(--primary-blue); color: white;' : 'background: var(--gray-100); color: var(--gray-700);' %>">
               Research
            </a>
            <a href="/campaigns/search?category=Other&sort=<%= typeof sortBy !== 'undefined' ? sortBy : 'newest' %>" 
               class="category-tag <%= typeof searchCategory !== 'undefined' && searchCategory === 'Other' ? 'active' : '' %>"
               style="padding: 0.5rem 1rem; border-radius: var(--border-radius-full); text-decoration: none; font-size: 0.875rem; transition: all var(--transition-fast); <%= typeof searchCategory !== 'undefined' && searchCategory === 'Other' ? 'background: var(--primary-blue); color: white;' : 'background: var(--gray-100); color: var(--gray-700);' %>">
               Other
            </a>
        </div>
    </div>

    <div class="campaign-grid">
        <% if (typeof campaigns !== 'undefined' && campaigns.length > 0) { %>
            <% campaigns.forEach(campaign => { %>
            <div class="campaign-card">
                <img src="<%= campaign.imageUrl || 'https://placehold.co/400x200/e5e7eb/1f2937?text=' + encodeURIComponent(campaign.title.substring(0, 20).replace(/\s+/g, '+')) %>", alt="<%= campaign.title %>" class="campaign-image">
                <div class="campaign-details">
                    <div class="campaign-header">
                        <span class="status-badge badge-<%= campaign.status === 'active' ? 'active' : (campaign.status === 'completed' ? 'completed' : 'expired') %>"><%= campaign.status.charAt(0).toUpperCase() + campaign.status.slice(1) %><%= campaign.status === 'active' ? ' • ' + campaign.daysLeftText : '' %></span>
                        <span class="status-badge badge-category"><%= campaign.category %></span>
                    </div>
                    <h3 class="campaign-name"><%= campaign.title %></h3>
                    <p class="campaign-author">by <%= campaign.creator.username %></p>
                    <div class="progress-container">
                        <div class="progress-track">
                            <div class="progress-fill" data-width="<%= campaign.fundingPercentage %>"></div>
                        </div>
                        <div class="progress-info">
                            <span><%= campaign.currentFunding %> BDT raised</span>
                            <span>of <%= campaign.fundingGoal %> BDT</span>
                        </div>
                    </div>
                    <div class="campaign-footer">
                        <a href="/campaigns/<%= campaign._id %>" class="view-button">View Details</a>
                    </div>
                </div>
            </div>
            <% }) %>
        <% } else { %>
            <div class="empty-state-box" style="text-align: center; padding: 4rem 2rem; background: white; border-radius: var(--border-radius-xl); box-shadow: var(--shadow-md); max-width: 600px; margin: 3rem auto;">
                <div style="font-size: 4rem; margin-bottom: 1rem;">🔍</div>
                <h3 class="empty-state-title" style="font-size: 1.5rem; font-weight: 700; color: var(--gray-800); margin-bottom: 0.5rem;">No campaigns found</h3>
                
                <% if (typeof searchQuery !== 'undefined' && searchQuery && searchQuery.trim() !== '') { %>
                    <p class="empty-state-text" style="color: var(--gray-600); margin-bottom: 1.5rem;">
                        No results matched "<strong><%= searchQuery %></strong>". Try different keywords or browse all campaigns.
                    </p>
                    <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
                        <a href="/campaigns/search?q=&category=all&sort=newest" class="btn btn--primary">Browse All Campaigns</a>
                        <a href="/builder/create" class="btn btn--secondary">Create Your Own</a>
                    </div>
                <% } else if (typeof searchCategory !== 'undefined' && searchCategory && searchCategory !== 'all') { %>
                    <p class="empty-state-text" style="color: var(--gray-600); margin-bottom: 1.5rem;">
                        There are no campaigns in the <strong><%= searchCategory %></strong> category yet.
                    </p>
                    <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
                        <a href="/campaigns/search?category=all&sort=<%= typeof sortBy !== 'undefined' ? sortBy : 'newest' %>" class="btn btn--primary">View All Categories</a>
                        <a href="/builder/create?category=<%= encodeURIComponent(searchCategory) %>" class="btn btn--secondary">Create in This Category</a>
                    </div>
                <% } else { %>
                    <p class="empty-state-text" style="color: var(--gray-600); margin-bottom: 1.5rem;">
                        Be the first to create a campaign and inspire others!
                    </p>
                    <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
                        <% if (typeof user !== 'undefined' && user) { %>
                            <a href="/builder/create" class="btn btn--primary">Create Your First Campaign</a>
                        <% } else { %>
                            <a href="/register" class="btn btn--primary">Get Started</a>
                            <a href="/campaigns/search?q=&category=all&sort=newest" class="btn btn--secondary">Browse All Campaigns</a>
                        <% } %>
                    </div>
                <% } %>
                
                <!-- Popular Categories Suggestions -->
                <div style="margin-top: 2rem; padding-top: 2rem; border-top: 1px solid var(--gray-200);">
                    <h4 style="font-size: 1rem; font-weight: 600; color: var(--gray-700); margin-bottom: 1rem;">📊 Browse Popular Categories:</h4>
                    <div style="display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap;">
                        <a href="/campaigns/search?category=Technology&sort=newest" class="category-tag" style="background: var(--gray-100); color: var(--gray-700); padding: 0.5rem 1rem; border-radius: var(--border-radius-full); text-decoration: none; font-size: 0.875rem;">Technology</a>
                        <a href="/campaigns/search?category=Education&sort=newest" class="category-tag" style="background: var(--gray-100); color: var(--gray-700); padding: 0.5rem 1rem; border-radius: var(--border-radius-full); text-decoration: none; font-size: 0.875rem;">Education</a>
                        <a href="/campaigns/search?category=Social Impact&sort=newest" class="category-tag" style="background: var(--gray-100); color: var(--gray-700); padding: 0.5rem 1rem; border-radius: var(--border-radius-full); text-decoration: none; font-size: 0.875rem;">Social Impact</a>
                        <a href="/campaigns/search?category=Arts & Culture&sort=newest" class="category-tag" style="background: var(--gray-100); color: var(--gray-700); padding: 0.5rem 1rem; border-radius: var(--border-radius-full); text-decoration: none; font-size: 0.875rem;">Arts & Culture</a>
                    </div>
                </div>
            </div>
        <% } %>
    </div>
    
    <!-- Pagination Controls -->
    <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
    <div class="pagination-controls" style="display: flex; justify-content: center; align-items: center; gap: 0.5rem; margin-top: 3rem; padding: 2rem;">
        <% if (typeof hasPrevPage !== 'undefined' && hasPrevPage) { %>
            <a href="/campaigns/search?q=<%= typeof searchQuery !== 'undefined' ? encodeURIComponent(searchQuery) : '' %>&category=<%= typeof searchCategory !== 'undefined' ? searchCategory : 'all' %>&sort=<%= typeof sortBy !== 'undefined' ? sortBy : 'newest' %>&page=<%= prevPage %>" 
               class="pagination-btn" 
               style="padding: 0.75rem 1.5rem; background: white; border: 2px solid var(--gray-300); border-radius: var(--border-radius-lg); text-decoration: none; color: var(--gray-700); font-weight: 600; transition: all var(--transition-fast);">
               ← Previous
            </a>
        <% } %>
        
        <% for (let i = 1; i <= totalPages; i++) { %>
            <% if (i === currentPage) { %>
                <span style="padding: 0.75rem 1.5rem; background: var(--primary-blue); color: white; border-radius: var(--border-radius-lg); font-weight: 600;"><%= i %></span>
            <% } else if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) { %>
                <a href="/campaigns/search?q=<%= typeof searchQuery !== 'undefined' ? encodeURIComponent(searchQuery) : '' %>&category=<%= typeof searchCategory !== 'undefined' ? searchCategory : 'all' %>&sort=<%= typeof sortBy !== 'undefined' ? sortBy : 'newest' %>&page=<%= i %>" 
                   style="padding: 0.75rem 1.5rem; background: white; border: 2px solid var(--gray-300); border-radius: var(--border-radius-lg); text-decoration: none; color: var(--gray-700); font-weight: 600; transition: all var(--transition-fast);">
                   <%= i %>
                </a>
            <% } else if (i === currentPage - 3 || i === currentPage + 3) { %>
                <span style="padding: 0.75rem 0.5rem; color: var(--gray-500);">...</span>
            <% } %>
        <% } %>
        
        <% if (typeof hasNextPage !== 'undefined' && hasNextPage) { %>
            <a href="/campaigns/search?q=<%= typeof searchQuery !== 'undefined' ? encodeURIComponent(searchQuery) : '' %>&category=<%= typeof searchCategory !== 'undefined' ? searchCategory : 'all' %>&sort=<%= typeof sortBy !== 'undefined' ? sortBy : 'newest' %>&page=<%= nextPage %>" 
               class="pagination-btn" 
               style="padding: 0.75rem 1.5rem; background: white; border: 2px solid var(--gray-300); border-radius: var(--border-radius-lg); text-decoration: none; color: var(--gray-700); font-weight: 600; transition: all var(--transition-fast);">
               Next →
            </a>
        <% } %>
    </div>
    <% } %>
</section>