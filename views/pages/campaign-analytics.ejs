<% layout('layouts/main') -%>
<% title = 'Analytics - ' + campaign.title + ' - FundMyIdea BD' -%>

<div class="analytics-dashboard" style="padding: 2rem; max-width: 1400px; margin: 0 auto;">
    <!-- Header -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
        <div>
            <h1 class="heading-1" style="margin-bottom: 0.5rem;">📊 Campaign Analytics</h1>
            <p style="color: var(--gray-600);"><%= campaign.title %></p>
        </div>
        <div style="display: flex; gap: 1rem;">
            <a href="/campaigns/<%= campaign._id %>" class="btn btn--secondary">← Back to Campaign</a>
            <button id="downloadStatsBtn" class="btn btn--primary" onclick="downloadStatsAsImage()">📸 Download Stats</button>
        </div>
    </div>

    <!-- Key Metrics Cards -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
        <div style="background: white; padding: 1.5rem; border-radius: var(--border-radius-xl); box-shadow: var(--shadow-md); border-left: 4px solid var(--primary-blue);">
            <div style="font-size: 0.875rem; color: var(--gray-600); margin-bottom: 0.5rem;">Total Views</div>
            <div style="font-size: 2.5rem; font-weight: 700; color: var(--primary-blue);"><%= campaign.views.toLocaleString() %></div>
            <div style="font-size: 0.75rem; color: var(--gray-500); margin-top: 0.5rem;">Unique page visits</div>
        </div>
        
        <div style="background: white; padding: 1.5rem; border-radius: var(--border-radius-xl); box-shadow: var(--shadow-md); border-left: 4px solid var(--secondary-green);">
            <div style="font-size: 0.875rem; color: var(--gray-600); margin-bottom: 0.5rem;">Conversion Rate</div>
            <div style="font-size: 2.5rem; font-weight: 700; color: var(--secondary-green);"><%= conversionRate %>%</div>
            <div style="font-size: 0.75rem; color: var(--gray-500); margin-top: 0.5rem;">Views to donations</div>
        </div>
        
        <div style="background: white; padding: 1.5rem; border-radius: var(--border-radius-xl); box-shadow: var(--shadow-md); border-left: 4px solid #f59e0b;">
            <div style="font-size: 0.875rem; color: var(--gray-600); margin-bottom: 0.5rem;">Avg Donation</div>
            <div style="font-size: 2.5rem; font-weight: 700; color: #f59e0b;"><%= avgDonation.toLocaleString() %> BDT</div>
            <div style="font-size: 0.75rem; color: var(--gray-500); margin-top: 0.5rem;">Per backer</div>
        </div>
        
        <div style="background: white; padding: 1.5rem; border-radius: var(--border-radius-xl); box-shadow: var(--shadow-md); border-left: 4px solid #dc2626;">
            <div style="font-size: 0.875rem; color: var(--gray-600); margin-bottom: 0.5rem;">Days Remaining</div>
            <div style="font-size: 2.5rem; font-weight: 700; color: #dc2626;"><%= campaign.daysRemaining %></div>
            <div style="font-size: 0.75rem; color: var(--gray-500); margin-top: 0.5rem;"><%= campaign.deadline.toLocaleDateString() %></div>
        </div>
    </div>

    <!-- Funding Progress Overview -->
    <div style="background: white; padding: 2rem; border-radius: var(--border-radius-xl); box-shadow: var(--shadow-md); margin-bottom: 2rem;">
        <h2 class="heading-3" style="margin-bottom: 1.5rem;">💰 Funding Progress</h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2rem; margin-bottom: 1.5rem;">
            <div>
                <div style="font-size: 0.875rem; color: var(--gray-600); margin-bottom: 0.5rem;">Current Funding</div>
                <div style="font-size: 2rem; font-weight: 700; color: var(--secondary-green);"><%= campaign.currentFunding.toLocaleString() %> BDT</div>
            </div>
            <div>
                <div style="font-size: 0.875rem; color: var(--gray-600); margin-bottom: 0.5rem;">Funding Goal</div>
                <div style="font-size: 2rem; font-weight: 700; color: var(--gray-700);"><%= campaign.fundingGoal.toLocaleString() %> BDT</div>
            </div>
            <div>
                <div style="font-size: 0.875rem; color: var(--gray-600); margin-bottom: 0.5rem;">Progress</div>
                <div style="font-size: 2rem; font-weight: 700; color: var(--primary-blue);"><%= campaign.fundingPercentage %>%</div>
            </div>
            <div>
                <div style="font-size: 0.875rem; color: var(--gray-600); margin-bottom: 0.5rem;">Total Backers</div>
                <div style="font-size: 2rem; font-weight: 700; color: #8b5cf6;"><%= campaign.backers.length %></div>
            </div>
        </div>
        <div style="width: 100%; background: var(--gray-200); height: 12px; border-radius: 9999px; overflow: hidden;">
            <div style="background: linear-gradient(90deg, var(--primary-blue), var(--secondary-green)); height: 100%; width: <%= campaign.fundingPercentage %>%; transition: width 0.5s ease;"></div>
        </div>
    </div>

    <!-- Daily Donations Chart -->
    <div style="background: white; padding: 2rem; border-radius: var(--border-radius-xl); box-shadow: var(--shadow-md); margin-bottom: 2rem;">
        <h2 class="heading-3" style="margin-bottom: 1.5rem;">📈 Daily Donations (Last 30 Days)</h2>
        <canvas id="donationsChart" height="80"></canvas>
    </div>

    <!-- University Breakdown -->
    <% if (universityData.length > 0) { %>
    <div style="background: white; padding: 2rem; border-radius: var(--border-radius-xl); box-shadow: var(--shadow-md); margin-bottom: 2rem;">
        <h2 class="heading-3" style="margin-bottom: 1.5rem;">🎓 Donor University Breakdown</h2>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: center;">
            <div>
                <canvas id="universityChart" height="300"></canvas>
            </div>
            <div style="max-height: 400px; overflow-y: auto;">
                <table style="width: 100%; border-collapse: collapse;">
                    <thead>
                        <tr style="border-bottom: 2px solid var(--gray-200);">
                            <th style="text-align: left; padding: 0.75rem; color: var(--gray-600); font-size: 0.875rem;">University</th>
                            <th style="text-align: right; padding: 0.75rem; color: var(--gray-600); font-size: 0.875rem;">Amount</th>
                            <th style="text-align: right; padding: 0.75rem; color: var(--gray-600); font-size: 0.875rem;">%</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% universityData.sort((a, b) => b.amount - a.amount).forEach((uni, index) => { %>
                            <tr style="border-bottom: 1px solid var(--gray-100);">
                                <td style="padding: 0.75rem; font-weight: 600; color: var(--gray-800);">
                                    <% if (index === 0) { %>🥇<% } else if (index === 1) { %>🥈<% } else if (index === 2) { %>🥉<% } %>
                                    <%= uni.name %>
                                </td>
                                <td style="text-align: right; padding: 0.75rem; font-weight: 700; color: var(--secondary-green);">
                                    <%= uni.amount.toLocaleString() %> BDT
                                </td>
                                <td style="text-align: right; padding: 0.75rem; color: var(--gray-600);">
                                    <%= ((uni.amount / campaign.currentFunding) * 100).toFixed(1) %>%
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <% } %>

    <!-- Recent Donors -->
    <div style="background: white; padding: 2rem; border-radius: var(--border-radius-xl); box-shadow: var(--shadow-md); margin-bottom: 2rem;">
        <h2 class="heading-3" style="margin-bottom: 1.5rem;">💝 Recent Donors</h2>
        <% if (campaign.backers.length > 0) { %>
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem;">
                <% const sortedBackers = campaign.backers.slice().sort((a, b) => new Date(b.donatedAt) - new Date(a.donatedAt)).slice(0, 12); %>
                <% sortedBackers.forEach(backer => { %>
                    <div style="border: 1px solid var(--gray-200); border-radius: var(--border-radius-md); padding: 1rem; display: flex; align-items: center; gap: 1rem;">
                        <div style="width: 48px; height: 48px; background: linear-gradient(135deg, var(--primary-blue), var(--primary-blue-light)); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-weight: 700; font-size: 1.25rem;">
                            <%= (backer.user?.username || 'A').charAt(0).toUpperCase() %>
                        </div>
                        <div style="flex: 1;">
                            <div style="font-weight: 600; color: var(--gray-800);"><%= backer.user?.username || 'Anonymous' %></div>
                            <div style="font-size: 0.875rem; color: var(--gray-600);"><%= backer.amount.toLocaleString() %> BDT</div>
                            <div style="font-size: 0.75rem; color: var(--gray-500);"><%= new Date(backer.donatedAt).toLocaleDateString() %></div>
                        </div>
                        <% if (backer.paymentMethod === 'bkash') { %>
                            <div style="font-size: 0.75rem; background: #ecfdf5; color: var(--secondary-green); padding: 0.25rem 0.5rem; border-radius: var(--border-radius-full);">bKash</div>
                        <% } %>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <p style="color: var(--gray-600); text-align: center; padding: 2rem;">No donors yet. Be the first to donate!</p>
        <% } %>
    </div>
</div>

<!-- Chart.js CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<script>
    // Daily Donations Line Chart
    const donationsCtx = document.getElementById('donationsChart').getContext('2d');
    const donationsData = <%= JSON.stringify(donationsByDay) %>;
    
    new Chart(donationsCtx, {
        type: 'line',
        data: {
            labels: donationsData.map(d => d.date),
            datasets: [{
                label: 'Donation Amount (BDT)',
                data: donationsData.map(d => d.amount),
                borderColor: '#4f46e5',
                backgroundColor: 'rgba(79, 70, 229, 0.1)',
                tension: 0.4,
                fill: true
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: { display: false },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            return context.parsed.y.toLocaleString('en-BD') + ' BDT';
                        }
                    }
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: {
                        callback: function(value) {
                            return value.toLocaleString('en-BD') + ' BDT';
                        }
                    }
                }
            }
        }
    });
    
    // University Breakdown Donut Chart
    <% if (universityData.length > 0) { %>
    const uniCtx = document.getElementById('universityChart').getContext('2d');
    const universityData = <%= JSON.stringify(universityData) %>;
    
    new Chart(uniCtx, {
        type: 'doughnut',
        data: {
            labels: universityData.map(u => u.name),
            datasets: [{
                data: universityData.map(u => u.amount),
                backgroundColor: [
                    '#4f46e5', '#06b6d4', '#10b981', '#f59e0b', '#ef4444', 
                    '#8b5cf6', '#ec4899', '#6366f1', '#14b8a6', '#f97316'
                ],
                borderWidth: 2,
                borderColor: '#ffffff'
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: {
                        padding: 15,
                        font: { size: 11 }
                    }
                },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            const total = context.dataset.data.reduce((a, b) => a + b, 0);
                            const percentage = ((context.parsed / total) * 100).toFixed(1);
                            return context.label + ': ' + context.parsed.toLocaleString('en-BD') + ' BDT (' + percentage + '%)';
                        }
                    }
                }
            }
        }
    });
    <% } %>
    
    // Download stats as image using html2canvas
    async function downloadStatsAsImage() {
        try {
            const html2canvas = (await import('https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js')).default;
            
            const dashboard = document.querySelector('.analytics-dashboard');
            const canvas = await html2canvas(dashboard, {
                scale: 2,
                useCORS: true,
                logging: false
            });
            
            const link = document.createElement('a');
            link.download = `<%= campaign.title.replace(/[^a-z0-9]/gi, '_') %>-analytics.png`;
            link.href = canvas.toDataURL('image/png');
            link.click();
            
            alert('📊 Analytics downloaded successfully!');
        } catch (error) {
            console.error('Error downloading stats:', error);
            alert('Failed to download stats. Please try again.');
        }
    }
</script>

<style>
    @media print {
        .btn { display: none; }
        body { background: white; }
        .analytics-dashboard { max-width: 100%; }
    }
</style>
