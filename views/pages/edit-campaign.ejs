<% layout('layouts/main') -%>
<% title = 'Edit Campaign - FundMyIdea BD' -%>

<form class="auth-form campaign-form" method="POST" action="/campaigns/<%= campaign ? campaign._id : 'id' %>/edit" enctype="multipart/form-data">
    <h2 class="form-title">Edit Your Campaign</h2>
    
    <% if (typeof error !== 'undefined' && error) { %>
        <div style="background-color: #fee2e2; color: #dc2626; padding: 1rem; border-radius: 0.5rem; margin-bottom: 1rem; border: 1px solid #fecaca;">
            <%= error %>
        </div>
    <% } %>
    
    <div class="form-group">
        <label class="form-label">Campaign Title</label>
        <input type="text" name="title" class="form-control" placeholder="e.g. Eco-Friendly Waste App for Dhaka" 
               value="<%= campaign ? campaign.title : '' %>" required>
    </div>
    
    <div class="form-group">
        <label class="form-label">Description</label>
        <textarea name="description" class="form-control textarea" rows="6" placeholder="Explain your idea, its impact, and how the funds will be used..." required><%= campaign ? campaign.description : '' %></textarea>
    </div>
    
    <div class="form-row">
        <div class="form-group">
            <label class="form-label">Funding Goal (BDT)</label>
            <input type="number" name="fundingGoal" class="form-control" placeholder="e.g. 50000" min="1000" 
                   value="<%= campaign ? campaign.fundingGoal : '' %>" required>
        </div>
        <div class="form-group">
            <label class="form-label">Campaign Deadline</label>
            <input type="date" name="deadline" class="form-control" 
                   value="<%= campaign ? campaign.deadline.toISOString().split('T')[0] : '' %>" required>
        </div>
    </div>
    
    <div class="form-group">
        <label class="form-label">Category</label>
        <select name="category" class="form-control" required>
            <option value="">Select a category</option>
            <option value="Technology" <%= campaign && campaign.category === 'Technology' ? 'selected' : '' %>>Technology</option>
            <option value="Education" <%= campaign && campaign.category === 'Education' ? 'selected' : '' %>>Education</option>
            <option value="Social Impact" <%= campaign && campaign.category === 'Social Impact' ? 'selected' : '' %>>Social Impact</option>
            <option value="Arts & Culture" <%= campaign && campaign.category === 'Arts & Culture' ? 'selected' : '' %>>Arts & Culture</option>
            <option value="Research" <%= campaign && campaign.category === 'Research' ? 'selected' : '' %>>Research</option>
            <option value="Other" <%= campaign && campaign.category === 'Other' ? 'selected' : '' %>>Other</option>
        </select>
    </div>
    
    <div class="form-group">
        <label class="form-label">Campaign Image</label>
        <% if (campaign && campaign.imageUrl) { %>
            <div style="margin-bottom: 1rem;">
                <img src="<%= campaign.imageUrl %>" alt="Current image" style="max-width: 200px; border-radius: 0.5rem;">
                <p style="font-size: 0.875rem; color: var(--gray-600);">Current image</p>
            </div>
        <% } %>
        <input type="file" name="image" class="form-control" accept="image/*">
        <small style="color: var(--gray-500); font-size: 0.875rem;">Upload a new image to replace current one (JPG, PNG, max 5MB)</small>
    </div>
    
    <div style="display: flex; gap: 1rem; margin-top: 2rem;">
        <button type="submit" class="submit-button" style="background-color: var(--secondary-green);">Update Campaign</button>
        <a href="/campaigns/<%= campaign ? campaign._id : 'id' %>" class="secondary-button">Cancel</a>
    </div>
</form>