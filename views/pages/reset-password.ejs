<% layout('layouts/main') -%>
<% title = 'Reset Password - FundMyIdea BD' -%>
<form method="POST" action="/reset-password/<%= typeof token !== 'undefined' ? token : '' %>" class="form-card auth-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <h2 class="heading-2 auth-form-title">Reset Your Password</h2>
    <% if (typeof error !== 'undefined' && error) { %>
        <div class="error-banner">
            <%= error %>
        </div>
    <% } %>
    <% if (typeof success !== 'undefined' && success) { %>
        <div class="success-banner">
            <%= success %>
        </div>
    <% } %>
    <div class="form-group">
        <label for="password" class="form-label">New Password</label>
        <input 
            type="password" 
            id="password" 
            name="password" 
            class="form-control" 
            placeholder="Enter new password"
            minlength="6"
            required
        >
        <small class="form-helper">Password must be at least 6 characters</small>
    </div>
    <div class="form-group">
        <label for="confirmPassword" class="form-label">Confirm Password</label>
        <input 
            type="password" 
            id="confirmPassword" 
            name="confirmPassword" 
            class="form-control" 
            placeholder="Confirm new password"
            minlength="6"
            required
        >
    </div>
    <button type="submit" class="btn btn--primary btn--full">
        Reset Password
    </button>
    <div class="form-footer">
                <p>Remember your password? <a href="/login" class="form-link">Login here</a></p>
            </div>
    </form>
<script>
    // Client-side password matching validation
    document.querySelector('form').addEventListener('submit', function(e) {
        const password = document.getElementById('password').value;
        const confirmPassword = document.getElementById('confirmPassword').value;
        if (password !== confirmPassword) {
            e.preventDefault();
            alert('Passwords do not match!');
        }
    });
</script>
