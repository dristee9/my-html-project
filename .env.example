PORT=3000
MONGODB_URI=your_mongodb_connection_string_here
JWT_SECRET=your_super_secret_jwt_key_change_in_production
CSRF_SECRET=your_csrf_secret_key_change_in_production
NODE_ENV=development

# Register at bKash Developer Portal. Get sandbox appKey, appSecret, username, password
BKASH_APP_KEY=your_sandbox_app_key
BKASH_APP_SECRET=your_sandbox_app_secret
BKASH_USERNAME=your_sandbox_username
BKASH_PASSWORD=your_sandbox_password

# Email Configuration (Gmail example)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM=FundMyIdea BD <noreply@fundmyidea.bd>
