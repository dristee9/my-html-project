<% layout('layouts/main') -%>
<% title = campaign.title + ' - FundMyIdea BD' -%>
<% if (campaign.pageBuilder && campaign.pageBuilder.enabled) { %>
    <% if (campaign.pageBuilder.customCSS) { %>
        <style><%- campaign.pageBuilder.customCSS %></style>
    <% } %>
    <style>
        :root {
            --primary-blue: <%= campaign.pageBuilder.globalStyles.primaryColor || '#3b82f6' %>;
            --primary-blue-light: <%= campaign.pageBuilder.globalStyles.primaryLight || '#2563eb' %>;
            --secondary-green: <%= campaign.pageBuilder.globalStyles.secondaryColor || '#16a34a' %>;
            --accent-color: <%= campaign.pageBuilder.globalStyles.accentColor || '#8b5cf6' %>;
            --background-color: <%= campaign.pageBuilder.globalStyles.backgroundColor || '#ffffff' %>;
            --font-family: <%= campaign.pageBuilder.globalStyles.fontFamily || '-apple-system, BlinkMacSystemFont, sans-serif' %>;
        }
        body {
            font-family: var(--font-family);
        }
    </style>
    <% const orderedSections = campaign.pageBuilder.sections.slice().sort((a, b) => a.order - b.order); %>
    <% orderedSections.forEach(section => { %>
        <section class="custom-section <%= section.settings.customClass || '' %>" 
                 style="
                     background-color: <%= section.settings.backgroundColor || '#ffffff' %>;
                     color: <%= section.settings.textColor || '#000000' %>;
                     padding: <%= section.settings.padding.top %>px <%= section.settings.padding.right %>px <%= section.settings.padding.bottom %>px <%= section.settings.padding.left %>px;
                     margin: <%= section.settings.margin.top %>px 0 <%= section.settings.margin.bottom %>px 0;
                     border-radius: <%= section.settings.borderRadius %>px;
                     box-shadow: <%= section.settings.boxShadow || 'none' %>;
                 ">
            <%- include('../components/section-' + section.type, { content: section.content, campaign: campaign }) %>
        </section>
    <% }); %>
    <% if (!campaign.pageBuilder.sections.some(s => s.type === 'form')) { %>
        <section class="custom-section donation-section bg-gray-50 py-8 px-6">
            <div class="container">
                <h2 class="text-2xl font-bold text-center mb-6">Support This Campaign</h2>
                <% if (typeof user !== 'undefined' && user && campaign.creator._id.toString() !== user._id.toString()) { %>
                    <% if (typeof hasDonated !== 'undefined' && hasDonated) { %>
                        <div class="success-banner max-w-2xl mx-auto">
                            <h3>Thank You for Your Support!</h3>
                            <p>You've already contributed to this campaign. Your support means the world to the creator.</p>
                        </div>
                    <% } else if (campaign.status === 'active') { %>
                        <div class="donate-cta-card" style="background: linear-gradient(135deg, var(--primary-blue), var(--primary-blue-light)); color: white; padding: 2.5rem; border-radius: var(--border-radius-xl); text-align: center; margin: 2rem auto; box-shadow: var(--shadow-lg); max-width: 600px;">
                            <h3 class="heading-4" style="margin-bottom: 1rem;">Ready to Make a Difference?</h3>
                            <p style="margin-bottom: 1.5rem; opacity: 0.95;">Your contribution can help bring this student's innovative idea to life.</p>
                            <a href="/campaigns/<%= campaign._id %>/donate" class="btn btn--success btn--lg" style="display: inline-flex; align-items: center; gap: 0.75rem; background: white; color: var(--primary-blue); font-weight: 700; padding: 1rem 2.5rem; border-radius: var(--border-radius-full); text-decoration: none; transition: all var(--transition-fast);">
                                <span style="font-size: 1.5rem;">💰</span>
                                <span>Donate Now via bKash</span>
                            </a>
                            <p style="margin-top: 1rem; font-size: 0.875rem; opacity: 0.85;">
                                <i class="security-icon">🔒</i> Secure payment processing
                            </p>
                        </div>
                    <% } else { %>
                        <p style="text-align: center; color: var(--gray-600); margin: 2rem 0;">This campaign is no longer accepting donations.</p>
                    <% } %>
                <% } else if (typeof user !== 'undefined' && user && campaign.creator._id.toString() === user._id.toString()) { %>
                    <div class="card-shadow max-w-2xl mx-auto">
                        <h3 class="text-xl font-semibold mb-4">Creator Tools</h3>
                        <div class="flex gap-4 mb-6">
                            <a href="/builder/<%= campaign._id %>/edit" class="btn btn--primary">Edit Page</a>
                            <button onclick="showDeleteModal()" class="btn-danger">Delete Campaign</button>
                        </div>
                        <h4 class="text-lg font-semibold mb-4">Recent Supporters (<%= campaign.backers.length %>)</h4>
                        <% if (campaign.backers.length > 0) { %>
                            <div class="max-h-72 overflow-y-auto">
                                <% campaign.backers.slice(-5).reverse().forEach(backer => { %>
                                    <div class="donor-list-item">
                                        <div>
                                            <div class="donor-name"><%= backer.user.username || 'Anonymous' %></div>
                                            <div class="donor-message"><%= backer.message || 'No message' %></div>
                                        </div>
                                        <div class="text-right">
                                            <div class="donor-amount"><%= backer.amount %> BDT</div>
                                            <div class="donor-date"><%= new Date(backer.donatedAt).toLocaleDateString() %></div>
                                        </div>
                                    </div>
                                <% }); %>
                            </div>
                        <% } else { %>
                            <p class="empty-state">No supporters yet. Share your campaign to start receiving donations!</p>
                        <% } %>
                    </div>
                <% } %>
            </div>
        </section>
    <% } %>
    <%- include('../partials/modal-delete-campaign', { campaignId: campaign._id }) %>
<% } else { %>
    <div class="campaign-detail-page">
        <div class="campaign-header-image">
            <img src="<%= campaign.imageUrl || 'https://placehold.co/1200x400/e5e7eb/1f2937?text=' + encodeURIComponent(campaign.title.substring(0, 30).replace(/\s+/g, '+')) %>" alt="<%= campaign.title %>" class="campaign-main-image">
        </div>
        <div class="campaign-content">
            <div class="campaign-info">
                <div class="campaign-header">
                    <span class="status-badge badge-<%= campaign.status === 'active' ? 'active' : 'completed' %>"><%= campaign.status.charAt(0).toUpperCase() + campaign.status.slice(1) %> • <%= campaign.daysLeftText %></span>
                    <span class="status-badge badge-category"><%= campaign.category %></span>
                </div>
                <h1 class="heading-1"><%= campaign.title %></h1>
                <p class="campaign-author-detail">by <%= campaign.creator.username %>, <%= campaign.creator.university %> Student</p>
                <div class="funding-summary">
                    <%- include('../partials/campaign-stats', { campaign: campaign }) %>
                </div>
            </div>
            <div class="campaign-description">
                <h2 class="heading-3">About this Campaign</h2>
                <div class="description-content">
                    <p><%= campaign.description %></p>
                </div>
            </div>
            <% if (typeof user !== 'undefined' && user && campaign.creator._id.toString() !== user._id.toString()) { %>
            <div class="donation-section">
                <h2 class="heading-3">Support this Project</h2>
                <% if (typeof hasDonated !== 'undefined' && hasDonated) { %>
                    <div class="success-banner mb-6 text-center">
                        <h3 class="mb-2">Thank You for Your Support!</h3>
                        <p>You've already contributed to this campaign. Your support means the world to the creator.</p>
                    </div>
                <% } else if (campaign.status === 'active') { %>
                    <div class="donate-cta-card" style="background: linear-gradient(135deg, var(--primary-blue), var(--primary-blue-light)); color: white; padding: 2.5rem; border-radius: var(--border-radius-xl); text-align: center; margin: 2rem 0; box-shadow: var(--shadow-lg);">
                        <h3 class="heading-4" style="margin-bottom: 1rem;">Ready to Make a Difference?</h3>
                        <p style="margin-bottom: 1.5rem; opacity: 0.95;">Your contribution can help bring this student's innovative idea to life.</p>
                        <a href="/campaigns/<%= campaign._id %>/donate" class="btn btn--success btn--lg" style="display: inline-flex; align-items: center; gap: 0.75rem; background: white; color: var(--primary-blue); font-weight: 700; padding: 1rem 2.5rem; border-radius: var(--border-radius-full); text-decoration: none; transition: all var(--transition-fast);">
                            <span style="font-size: 1.5rem;">💰</span>
                            <span>Donate Now via bKash</span>
                        </a>
                        <p style="margin-top: 1rem; font-size: 0.875rem; opacity: 0.85;">
                            <i class="security-icon">🔒</i> Secure payment processing
                        </p>
                    </div>
                <% } else { %>
                    <p style="text-align: center; color: var(--gray-600); margin: 2rem 0;">This campaign is no longer accepting donations.</p>
                <% } %>
            </div>
            <% } %>
        </div>
    </div>
<% } %>