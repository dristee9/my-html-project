<% layout('layouts/main') -%>
<% title = 'Explore Campaigns - FundMyIdea BD' -%>
<section class="page-section">
    <% if (typeof searchQuery !== 'undefined' && searchQuery && searchQuery.trim() !== '') { %>
        <h1 class="heading-1">Search Results for: "<%= searchQuery %>"</h1>
    <% } else if (typeof searchCategory !== 'undefined' && searchCategory && searchCategory !== 'all') { %>
        <h1 class="heading-1">Browse Category: <%= searchCategory %></h1>
    <% } else { %>
        <h1 class="heading-1">Explore Student Campaigns</h1>
    <% } %>
    <div class="search-filter-bar" style="background: white; padding: 2rem; border-radius: var(--border-radius-xl); box-shadow: var(--shadow-lg); margin-bottom: 2rem;">
        <form method="GET" action="/campaigns/search" class="search-filter-form">
            <div class="search-row" style="display: flex; gap: 1rem; margin-bottom: 1.5rem; flex-wrap: wrap;">
                <input type="text" name="q" class="form-control search-input" placeholder="Search campaigns..." value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>" style="flex: 1; min-width: 250px;">
                <select name="category" class="form-control" style="min-width: 180px;">
                    <option value="all">All Categories</option>
                    <option value="Technology" <%= typeof searchCategory !== 'undefined' && searchCategory === 'Technology' ? 'selected' : '' %>>Technology</option>
                    <option value="Education" <%= typeof searchCategory !== 'undefined' && searchCategory === 'Education' ? 'selected' : '' %>>Education</option>
                    <option value="Social Impact" <%= typeof searchCategory !== 'undefined' && searchCategory === 'Social Impact' ? 'selected' : '' %>>Social Impact</option>
                    <option value="Arts & Culture" <%= typeof searchCategory !== 'undefined' && searchCategory === 'Arts & Culture' ? 'selected' : '' %>>Arts & Culture</option>
                    <option value="Research" <%= typeof searchCategory !== 'undefined' && searchCategory === 'Research' ? 'selected' : '' %>>Research</option>
                    <option value="Other" <%= typeof searchCategory !== 'undefined' && searchCategory === 'Other' ? 'selected' : '' %>>Other</option>
                </select>
                <select name="university" class="form-control" style="min-width: 200px;">
                    <option value="all">All Universities</option>
                    <% if (typeof universities !== 'undefined' && universities.length > 0) { %>
                        <% universities.forEach(uni => { %>
                            <option value="<%= uni %>" <%= typeof searchUniversity !== 'undefined' && searchUniversity === uni ? 'selected' : '' %>><%= uni %></option>
                        <% }); %>
                    <% } %>
                </select>
                <select name="sort" class="form-control" style="min-width: 180px;">
                    <option value="newest" <%= typeof sortBy !== 'undefined' && sortBy === 'newest' ? 'selected' : '' %>>Newest First</option>
                    <option value="most-funded" <%= typeof sortBy !== 'undefined' && sortBy === 'most-funded' ? 'selected' : '' %>>Most Funded</option>
                    <option value="ending-soon" <%= typeof sortBy !== 'undefined' && sortBy === 'ending-soon' ? 'selected' : '' %>>Ending Soon</option>
                </select>
                <button type="submit" class="btn btn--primary" style="padding: 0.75rem 2rem;">Search</button>
            </div>
        </form>
        <div class="category-filters" style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 1rem;">
            <a href="/campaigns/search?category=all&university=<%= typeof searchUniversity !== 'undefined' ? searchUniversity : 'all' %>&sort=<%= typeof sortBy !== 'undefined' ? sortBy : 'newest' %>" 
               class="category-tag <%= typeof searchCategory === 'undefined' || searchCategory === 'all' ? 'active' : '' %>"
               style="padding: 0.5rem 1rem; border-radius: var(--border-radius-full); text-decoration: none; font-size: 0.875rem; transition: all var(--transition-fast); <%= typeof searchCategory === 'undefined' || searchCategory === 'all' ? 'background: var(--primary-blue); color: white;' : 'background: var(--gray-100); color: var(--gray-700);' %>">
               All
            </a>
            <a href="/campaigns/search?category=Technology&university=<%= typeof searchUniversity !== 'undefined' ? searchUniversity : 'all' %>&sort=<%= typeof sortBy !== 'undefined' ? sortBy : 'newest' %>" 
               class="category-tag <%= typeof searchCategory !== 'undefined' && searchCategory === 'Technology' ? 'active' : '' %>"
               style="padding: 0.5rem 1rem; border-radius: var(--border-radius-full); text-decoration: none; font-size: 0.875rem; transition: all var(--transition-fast); <%= typeof searchCategory !== 'undefined' && searchCategory === 'Technology' ? 'background: var(--primary-blue); color: white;' : 'background: var(--gray-100); color: var(--gray-700);' %>">
               Technology
            </a>
            <a href="/campaigns/search?category=Education&university=<%= typeof searchUniversity !== 'undefined' ? searchUniversity : 'all' %>&sort=<%= typeof sortBy !== 'undefined' ? sortBy : 'newest' %>" 
               class="category-tag <%= typeof searchCategory !== 'undefined' && searchCategory === 'Education' ? 'active' : '' %>"
               style="padding: 0.5rem 1rem; border-radius: var(--border-radius-full); text-decoration: none; font-size: 0.875rem; transition: all var(--transition-fast); <%= typeof searchCategory !== 'undefined' && searchCategory === 'Education' ? 'background: var(--primary-blue); color: white;' : 'background: var(--gray-100); color: var(--gray-700);' %>">
               Education
            </a>
            <a href="/campaigns/search?category=Social Impact&university=<%= typeof searchUniversity !== 'undefined' ? searchUniversity : 'all' %>&sort=<%= typeof sortBy !== 'undefined' ? sortBy : 'newest' %>" 
               class="category-tag <%= typeof searchCategory !== 'undefined' && searchCategory === 'Social Impact' ? 'active' : '' %>"
               style="padding: 0.5rem 1rem; border-radius: var(--border-radius-full); text-decoration: none; font-size: 0.875rem; transition: all var(--transition-fast); <%= typeof searchCategory !== 'undefined' && searchCategory === 'Social Impact' ? 'background: var(--primary-blue); color: white;' : 'background: var(--gray-100); color: var(--gray-700);' %>">
               Social Impact
            </a>
            <a href="/campaigns/search?category=Arts & Culture&university=<%= typeof searchUniversity !== 'undefined' ? searchUniversity : 'all' %>&sort=<%= typeof sortBy !== 'undefined' ? sortBy : 'newest' %>" 
               class="category-tag <%= typeof searchCategory !== 'undefined' && searchCategory === 'Arts & Culture' ? 'active' : '' %>"
               style="padding: 0.5rem 1rem; border-radius: var(--border-radius-full); text-decoration: none; font-size: 0.875rem; transition: all var(--transition-fast); <%= typeof searchCategory !== 'undefined' && searchCategory === 'Arts & Culture' ? 'background: var(--primary-blue); color: white;' : 'background: var(--gray-100); color: var(--gray-700);' %>">
               Arts & Culture
            </a>
            <a href="/campaigns/search?category=Research&university=<%= typeof searchUniversity !== 'undefined' ? searchUniversity : 'all' %>&sort=<%= typeof sortBy !== 'undefined' ? sortBy : 'newest' %>" 
               class="category-tag <%= typeof searchCategory !== 'undefined' && searchCategory === 'Research' ? 'active' : '' %>"
               style="padding: 0.5rem 1rem; border-radius: var(--border-radius-full); text-decoration: none; font-size: 0.875rem; transition: all var(--transition-fast); <%= typeof searchCategory !== 'undefined' && searchCategory === 'Research' ? 'background: var(--primary-blue); color: white;' : 'background: var(--gray-100); color: var(--gray-700);' %>">
               Research
            </a>
            <a href="/campaigns/search?category=Other&university=<%= typeof searchUniversity !== 'undefined' ? searchUniversity : 'all' %>&sort=<%= typeof sortBy !== 'undefined' ? sortBy : 'newest' %>" 
               class="category-tag <%= typeof searchCategory !== 'undefined' && searchCategory === 'Other' ? 'active' : '' %>"
               style="padding: 0.5rem 1rem; border-radius: var(--border-radius-full); text-decoration: none; font-size: 0.875rem; transition: all var(--transition-fast); <%= typeof searchCategory !== 'undefined' && searchCategory === 'Other' ? 'background: var(--primary-blue); color: white;' : 'background: var(--gray-100); color: var(--gray-700);' %>">
               Other
            </a>
        </div>
        <% if (typeof universities !== 'undefined' && universities.length > 0) { %>
            <div class="university-filters" style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--gray-200);">
                <span style="font-size: 0.75rem; font-weight: 600; color: var(--gray-600); text-transform: uppercase; letter-spacing: 0.5px;"><i class="fa fa-graduation-cap"></i> Universities:</span>
                <a href="/campaigns/search?category=<%= typeof searchCategory !== 'undefined' ? searchCategory : 'all' %>&university=all&sort=<%= typeof sortBy !== 'undefined' ? sortBy : 'newest' %>" 
                   class="category-tag <%= typeof searchUniversity === 'undefined' || searchUniversity === 'all' ? 'active' : '' %>"
                   style="padding: 0.375rem 0.875rem; border-radius: var(--border-radius-full); text-decoration: none; font-size: 0.75rem; transition: all var(--transition-fast); <%= typeof searchUniversity === 'undefined' || searchUniversity === 'all' ? 'background: var(--secondary-green); color: white;' : 'background: var(--gray-100); color: var(--gray-700);' %>">
                   All
                </a>
                <% universities.slice(0, 8).forEach(uni => { %>
                    <a href="/campaigns/search?category=<%= typeof searchCategory !== 'undefined' ? searchCategory : 'all' %>&university=<%= uni %>&sort=<%= typeof sortBy !== 'undefined' ? sortBy : 'newest' %>" 
                       class="category-tag <%= typeof searchUniversity !== 'undefined' && searchUniversity === uni ? 'active' : '' %>"
                       style="padding: 0.375rem 0.875rem; border-radius: var(--border-radius-full); text-decoration: none; font-size: 0.75rem; transition: all var(--transition-fast); <%= typeof searchUniversity !== 'undefined' && searchUniversity === uni ? 'background: var(--secondary-green); color: white;' : 'background: var(--gray-100); color: var(--gray-700);' %>">
                       <%= uni.split(' ').slice(0, 2).join(' ') %>
                    </a>
                <% }); %>
            </div>
        <% } %>
    </div>
    <div class="campaign-grid" id="campaignGrid">
        <% if (typeof campaigns !== 'undefined' && campaigns.length > 0) { %>
            <% campaigns.forEach(campaign => { %>
            <% 
                // Skip draft campaigns from public view
                if (campaign.status === 'draft') return;
            %>
            <div class="campaign-card">
                <div style="position: relative; overflow: hidden; border-radius: var(--border-radius-lg);">
                    <img src="<%= campaign.imageUrl || 'https://placehold.co/400x200/e5e7eb/1f2937?text=' + encodeURIComponent(campaign.title.substring(0, 20).replace(/\s+/g, '+')) %>" alt="<%= campaign.title %>" class="campaign-image" style="width: 100%; height: 200px; object-fit: cover; transition: transform 0.4s ease, filter 0.4s ease;">
                    <button onclick="toggleCompare('<%= campaign._id %>')" class="compare-btn" data-campaign-id="<%= campaign._id %>" 
                            style="position: absolute; top: 1rem; right: 1rem; background: rgba(255, 255, 255, 0.95); border: 2px solid var(--gray-300); border-radius: var(--border-radius-full); width: 40px; height: 40px; cursor: pointer; transition: all var(--transition-fast); display: flex; align-items: center; justify-content: center; font-size: 1.25rem; box-shadow: var(--shadow-sm); z-index: 10;">
                        <i class="fa fa-bar-chart"></i>
                    </button>
                    <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(0,0,0,0.8)); display: flex; flex-direction: column; justify-content: center; align-items: center; opacity: 0; transition: opacity 0.3s ease; padding: 1rem;">
                        <div style="color: white; font-size: 1.5rem; font-weight: 700; margin-bottom: 0.5rem; text-shadow: 0 2px 4px rgba(0,0,0,0.5);"><%= campaign.currentFunding %> BDT</div>
                        <div style="color: rgba(255,255,255,0.9); font-size: 0.875rem; margin-bottom: 1rem;">raised of <%= campaign.fundingGoal %> BDT</div>
                        <div style="width: 100%; background: rgba(255,255,255,0.3); border-radius: 9999px; height: 8px; overflow: hidden; margin-bottom: 0.75rem;">
                            <div style="background: linear-gradient(90deg, var(--secondary-green), var(--primary-blue)); height: 100%; width: <%= campaign.fundingPercentage %>%; transition: width 0.5s ease;"></div>
                        </div>
                        <div style="color: white; font-size: 0.75rem; font-weight: 600;"><%= campaign.fundingPercentage %>% Funded</div>
                        <% if (campaign.status === 'active') { %>
                            <div style="margin-top: 0.75rem; background: var(--primary-blue); color: white; padding: 0.5rem 1rem; border-radius: var(--border-radius-md); font-size: 0.875rem; font-weight: 600;"><%= campaign.daysLeftText %></div>
                        <% } %>
                    </div>
                </div>
                <div class="campaign-details">
                    <div class="campaign-header">
                        <% 
                            let statusBadgeClass = 'badge-' + campaign.status;
                            let statusText = campaign.status.charAt(0).toUpperCase() + campaign.status.slice(1);
                            if (campaign.status === 'active') {
                                statusText += ' • ' + campaign.daysLeftText;
                            } else if (campaign.status === 'expired' || campaign.status === 'cancelled') {
                                statusBadgeClass = 'badge-expired';
                            }
                        %>
                        <span class="status-badge <%= statusBadgeClass %>"><%= statusText %></span>
                        <span class="status-badge badge-category"><%= campaign.category %></span>
                        <span class="status-badge badge-university" style="background: linear-gradient(135deg, #8b5cf6, #7c3aed); color: white; font-size: 0.7rem;"><i class="fa fa-graduation-cap"></i> <%= campaign.creator.university ? campaign.creator.university.split(' ').slice(0, 2).join(' ') : 'University' %></span>
                    </div>
                    <h3 class="campaign-name"><%= campaign.title %></h3>
                    <p class="campaign-author">by <%= campaign.creator.username %> <span style="color: var(--gray-500); font-size: 0.875rem;">• <%= campaign.creator.university || 'Unknown University' %></span></p>
                    <% 
                        // Show "recently updated" badge if updated in last 24 hours
                        const hoursSinceUpdate = campaign.updatedAt ? Math.floor((new Date() - new Date(campaign.updatedAt)) / (1000 * 60 * 60)) : 999;
                        const isRecentlyUpdated = hoursSinceUpdate <= 24;
                    %>
                    <% if (isRecentlyUpdated) { %>
                        <div style="font-size: 0.75rem; color: var(--secondary-green); margin-bottom: 0.5rem;">
                            <i class="fa fa-refresh"></i> Updated <%= hoursSinceUpdate < 1 ? 'recently' : hoursSinceUpdate + 'h' %> ago
                        </div>
                    <% } %>
                    <div class="progress-container">
                        <div class="progress-track">
                            <div class="progress-fill" data-width="<%= campaign.fundingPercentage %>"></div>
                        </div>
                        <div class="progress-info">
                            <span><%= campaign.currentFunding %> BDT raised</span>
                            <span>of <%= campaign.fundingGoal %> BDT</span>
                        </div>
                    </div>
                    <div class="campaign-footer">
                        <a href="/campaigns/<%= campaign._id %>" class="view-button">View Details</a>
                    </div>
                </div>
            </div>
            <% }) %>
        <% } else { %>
            <div class="empty-state-box" style="text-align: center; padding: 4rem 2rem; background: white; border-radius: var(--border-radius-xl); box-shadow: var(--shadow-md); max-width: 600px; margin: 3rem auto;">
                <div style="font-size: 4rem; margin-bottom: 1rem;"><i class="fa fa-search"></i></div>
                <h3 class="empty-state-title" style="font-size: 1.5rem; font-weight: 700; color: var(--gray-800); margin-bottom: 0.5rem;">No campaigns found</h3>
                <% if (typeof searchQuery !== 'undefined' && searchQuery && searchQuery.trim() !== '') { %>
                    <p class="empty-state-text" style="color: var(--gray-600); margin-bottom: 1.5rem;">
                        No results matched "<strong><%= searchQuery %></strong>". Try different keywords or browse all campaigns.
                    </p>
                    <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
                        <a href="/campaigns/search?q=&category=all&sort=newest" class="btn btn--primary">Browse All Campaigns</a>
                        <a href="/builder/create" class="btn btn--secondary">Create Your Own</a>
                    </div>
                <% } else if (typeof searchCategory !== 'undefined' && searchCategory && searchCategory !== 'all') { %>
                    <p class="empty-state-text" style="color: var(--gray-600); margin-bottom: 1.5rem;">
                        There are no campaigns in the <strong><%= searchCategory %></strong> category yet.
                    </p>
                    <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
                        <a href="/campaigns/search?category=all&sort=<%= typeof sortBy !== 'undefined' ? sortBy : 'newest' %>" class="btn btn--primary">View All Categories</a>
                        <a href="/builder/create?category=<%= encodeURIComponent(searchCategory) %>" class="btn btn--secondary">Create in This Category</a>
                    </div>
                <% } else { %>
                    <p class="empty-state-text" style="color: var(--gray-600); margin-bottom: 1.5rem;">
                        Be the first to create a campaign and inspire others!
                    </p>
                    <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
                        <% if (typeof user !== 'undefined' && user) { %>
                            <a href="/builder/create" class="btn btn--primary">Create Your First Campaign</a>
                        <% } else { %>
                            <a href="/register" class="btn btn--primary">Get Started</a>
                            <a href="/campaigns/search?q=&category=all&sort=newest" class="btn btn--secondary">Browse All Campaigns</a>
                        <% } %>
                    </div>
                <% } %>
                <div style="margin-top: 2rem; padding-top: 2rem; border-top: 1px solid var(--gray-200);">
                    <h4 style="font-size: 1rem; font-weight: 600; color: var(--gray-700); margin-bottom: 1rem;"><i class="fa fa-bar-chart"></i> Browse Popular Categories:</h4>
                    <div style="display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap;">
                        <a href="/campaigns/search?category=Technology&sort=newest" class="category-tag" style="background: var(--gray-100); color: var(--gray-700); padding: 0.5rem 1rem; border-radius: var(--border-radius-full); text-decoration: none; font-size: 0.875rem;">Technology</a>
                        <a href="/campaigns/search?category=Education&sort=newest" class="category-tag" style="background: var(--gray-100); color: var(--gray-700); padding: 0.5rem 1rem; border-radius: var(--border-radius-full); text-decoration: none; font-size: 0.875rem;">Education</a>
                        <a href="/campaigns/search?category=Social Impact&sort=newest" class="category-tag" style="background: var(--gray-100); color: var(--gray-700); padding: 0.5rem 1rem; border-radius: var(--border-radius-full); text-decoration: none; font-size: 0.875rem;">Social Impact</a>
                        <a href="/campaigns/search?category=Arts & Culture&sort=newest" class="category-tag" style="background: var(--gray-100); color: var(--gray-700); padding: 0.5rem 1rem; border-radius: var(--border-radius-full); text-decoration: none; font-size: 0.875rem;">Arts & Culture</a>
                    </div>
                </div>
            </div>
        <% } %>
    </div>
    <% if (typeof user !== 'undefined' && user) { %>
    <div class="smart-recommendations-section" style="margin-top: 4rem; padding-top: 3rem; border-top: 2px solid var(--gray-200);">
        <h2 class="heading-2" style="margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
            <i class="fa fa-star"></i> You Might Like
            <span style="font-size: 0.875rem; font-weight: 400; color: var(--gray-600);">(Based on your donation history)</span>
        </h2>
        <% if (typeof recommendedCampaigns !== 'undefined' && recommendedCampaigns.length > 0) { %>
            <div class="recommendations-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem;">
                <% recommendedCampaigns.slice(0, 6).forEach(campaign => { %>
                    <div class="recommendation-card" style="background: white; border-radius: var(--border-radius-lg); padding: 1.5rem; box-shadow: var(--shadow-md); transition: all var(--transition-fast); border: 2px solid transparent;">
                        <div style="position: relative; overflow: hidden; border-radius: var(--border-radius-md); margin-bottom: 1rem;">
                            <img src="<%= campaign.imageUrl || 'https://placehold.co/400x200/e5e7eb/1f2937?text=' + encodeURIComponent(campaign.title.substring(0, 20).replace(/\s+/g, '+')) %>" 
                                 alt="<%= campaign.title %>" 
                                 style="width: 100%; height: 160px; object-fit: cover;">
                            <div style="position: absolute; top: 0.5rem; right: 0.5rem; background: linear-gradient(135deg, #fbbf24, #f59e0b); color: white; padding: 0.25rem 0.75rem; border-radius: var(--border-radius-full); font-size: 0.75rem; font-weight: 700; box-shadow: var(--shadow-sm);">
                                <i class="fa fa-bullseye"></i> Match
                            </div>
                        </div>
                        <h3 style="font-size: 1.125rem; font-weight: 700; color: var(--gray-800); margin-bottom: 0.5rem; line-height: 1.4;"><%= campaign.title %></h3>
                        <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem; font-size: 0.875rem; color: var(--gray-600);">
                            <span>by</span>
                            <strong><%= campaign.creator.username %></strong>
                            <% if (campaign.creator.university) { %>
                                <span>, <%= campaign.creator.university %></span>
                            <% } %>
                        </div>
                        <div style="margin-bottom: 1rem;">
                            <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem; font-size: 0.875rem;">
                                <span style="color: var(--gray-600);">Raised</span>
                                <span style="font-weight: 700; color: var(--secondary-green);"><%= campaign.currentFunding.toLocaleString() %> BDT</span>
                            </div>
                            <div style="background: var(--gray-200); height: 6px; border-radius: 3px; overflow: hidden;">
                                <div style="background: linear-gradient(90deg, var(--secondary-green), #34d399); height: 100%; width: <%= campaign.fundingPercentage %>%; transition: width 0.5s ease;"></div>
                            </div>
                        </div>
                        <div style="display: flex; justify-content: space-between; align-items: center; padding-top: 1rem; border-top: 1px solid var(--gray-200);">
                            <span style="font-size: 0.75rem; color: var(--gray-500);"><%= campaign.backers.length %> backers</span>
                            <a href="/campaigns/<%= campaign._id %>" class="btn btn--primary btn--sm">View →</a>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <div style="text-align: center; padding: 3rem 2rem; background: var(--gray-50); border-radius: var(--border-radius-lg);">
                <p style="color: var(--gray-600); font-size: 0.875rem;">Start donating to campaigns to get personalized recommendations!</p>
            </div>
        <% } %>
    </div>
    <% } %>
    <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
    <div class="pagination-controls" style="display: flex; justify-content: center; align-items: center; gap: 0.5rem; margin-top: 3rem; padding: 2rem;">
        <% if (typeof hasPrevPage !== 'undefined' && hasPrevPage) { %>
            <a href="/campaigns/search?q=<%= typeof searchQuery !== 'undefined' ? encodeURIComponent(searchQuery) : '' %>&category=<%= typeof searchCategory !== 'undefined' ? searchCategory : 'all' %>&sort=<%= typeof sortBy !== 'undefined' ? sortBy : 'newest' %>&page=<%= prevPage %>" 
               class="pagination-btn" 
               style="padding: 0.75rem 1.5rem; background: white; border: 2px solid var(--gray-300); border-radius: var(--border-radius-lg); text-decoration: none; color: var(--gray-700); font-weight: 600; transition: all var(--transition-fast);">
               ← Previous
            </a>
        <% } %>
        <% for (let i = 1; i <= totalPages; i++) { %>
            <% if (i === currentPage) { %>
                <span style="padding: 0.75rem 1.5rem; background: var(--primary-blue); color: white; border-radius: var(--border-radius-lg); font-weight: 600;"><%= i %></span>
            <% } else if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) { %>
                <a href="/campaigns/search?q=<%= typeof searchQuery !== 'undefined' ? encodeURIComponent(searchQuery) : '' %>&category=<%= typeof searchCategory !== 'undefined' ? searchCategory : 'all' %>&sort=<%= typeof sortBy !== 'undefined' ? sortBy : 'newest' %>&page=<%= i %>" 
                   style="padding: 0.75rem 1.5rem; background: white; border: 2px solid var(--gray-300); border-radius: var(--border-radius-lg); text-decoration: none; color: var(--gray-700); font-weight: 600; transition: all var(--transition-fast);">
                   <%= i %>
                </a>
            <% } else if (i === currentPage - 3 || i === currentPage + 3) { %>
                <span style="padding: 0.75rem 0.5rem; color: var(--gray-500);">...</span>
            <% } %>
        <% } %>
        <% if (typeof hasNextPage !== 'undefined' && hasNextPage) { %>
            <a href="/campaigns/search?q=<%= typeof searchQuery !== 'undefined' ? encodeURIComponent(searchQuery) : '' %>&category=<%= typeof searchCategory !== 'undefined' ? searchCategory : 'all' %>&sort=<%= typeof sortBy !== 'undefined' ? sortBy : 'newest' %>&page=<%= nextPage %>" 
               class="pagination-btn" 
               style="padding: 0.75rem 1.5rem; background: white; border: 2px solid var(--gray-300); border-radius: var(--border-radius-lg); text-decoration: none; color: var(--gray-700); font-weight: 600; transition: all var(--transition-fast);">
               Next →
            </a>
        <% } %>
    </div>
    <% } %>
</section>
<div id="compareBar" style="position: fixed; bottom: 0; left: 0; right: 0; background: linear-gradient(135deg, var(--primary-blue), var(--secondary-green)); color: white; padding: 1rem 2rem; box-shadow: 0 -4px 20px rgba(0,0,0,0.2); transform: translateY(100%); transition: transform var(--transition-normal); z-index: 1000;">
    <div style="max-width: 1400px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; gap: 1rem;">
        <div style="display: flex; align-items: center; gap: 1rem; flex: 1; overflow-x: auto;">
            <span style="font-weight: 700; font-size: 1rem; white-space: nowrap;"><i class="fa fa-bar-chart"></i> Compare:</span>
            <div id="compareThumbnails" style="display: flex; gap: 0.75rem;">
            </div>
        </div>
        <div style="display: flex; gap: 1rem; align-items: center;">
            <span id="compareCount" style="font-size: 0.875rem; opacity: 0.9;">0/3 selected</span>
            <button onclick="clearCompare()" class="btn btn--secondary btn--sm" style="background: rgba(255,255,255,0.2); border: none; color: white;">Clear</button>
            <a href="#" id="compareButton" onclick="navigateToCompare(); return false;" class="btn btn--primary btn--sm" style="background: white; color: var(--primary-blue); border: none; font-weight: 700;">Compare Now →</a>
        </div>
    </div>
</div>
<script>
// Campaign Comparison Feature using localStorage
function toggleCompare(campaignId) {
    let compareList = JSON.parse(localStorage.getItem('compareList') || '[]');
    const idx = compareList.indexOf(campaignId);
    if (idx > -1) {
        // Remove from comparison
        compareList.splice(idx, 1);
    } else if (compareList.length < 3) {
        // Add to comparison
        compareList.push(campaignId);
    } else {
        alert('You can compare up to 3 campaigns at once');
        return;
    }
    localStorage.setItem('compareList', JSON.stringify(compareList));
    updateCompareBar();
}
function clearCompare() {
    localStorage.removeItem('compareList');
    updateCompareBar();
}
function navigateToCompare() {
    const compareList = JSON.parse(localStorage.getItem('compareList') || '[]');
    if (compareList.length === 0) {
        alert('Please select at least 1 campaign to compare');
        return;
    }
    window.location.href = `/campaigns/compare?ids=${compareList.join(',')}`;
}
function updateCompareBar() {
    const compareList = JSON.parse(localStorage.getItem('compareList') || '[]');
    const compareBar = document.getElementById('compareBar');
    const compareThumbnails = document.getElementById('compareThumbnails');
    const compareCount = document.getElementById('compareCount');
    // Update count
    compareCount.textContent = `${compareList.length}/3 selected`;
    // Show/hide bar
    if (compareList.length > 0) {
        compareBar.style.transform = 'translateY(0)';
    } else {
        compareBar.style.transform = 'translateY(100%)';
        return;
    }
    // Clear thumbnails
    compareThumbnails.innerHTML = '';
    // Add thumbnail for each campaign
    compareList.forEach(campaignId => {
        const thumb = document.createElement('div');
        thumb.style.cssText = 'flex-shrink: 0; width: 60px; height: 60px; border-radius: 4px; overflow: hidden; position: relative; cursor: pointer; border: 2px solid white; box-shadow: 0 2px 8px rgba(0,0,0,0.2);';
        thumb.onclick = () => toggleCompare(campaignId);
        thumb.innerHTML = `
            <img src="https://placehold.co/60x60/e5e7eb/1f2937?text=C${campaignId.slice(-2)}" 
                 style="width: 100%; height: 100%; object-fit: cover;" 
                 alt="Campaign">
            <button onclick="event.stopPropagation(); toggleCompare('${campaignId}')" 
                    style="position: absolute; top: 2px; right: 2px; background: rgba(255,255,255,0.9); border: none; border-radius: 50%; width: 16px; height: 16px; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 10px; line-height: 1;">
                ✕
            </button>
        `;
        compareThumbnails.appendChild(thumb);
    });
}
// Initialize compare bar on page load
document.addEventListener('DOMContentLoaded', function() {
    updateCompareBar();
});
</script>