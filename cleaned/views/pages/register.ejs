<% layout('layouts/main') -%>
<% title = 'Register - FundMyIdea BD' -%>
<form class="form-card auth-form js-form" method="POST" action="/register">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <h2 class="heading-2 auth-form-title">Register as Student</h2>
    <% if (typeof error !== 'undefined' && error) { %>
        <div style="background-color: #fee2e2; color: #dc2626; padding: 1rem; border-radius: 0.5rem; margin-bottom: 1rem; border: 1px solid #fecaca;">
            <%= error %>
        </div>
    <% } %>
    <div class="form-group">
        <label class="form-label">Username</label>
        <input 
            type="text" 
            name="username"
            class="form-control" 
            placeholder="Choose a username" 
            value="<%= typeof formData !== 'undefined' && formData.username ? formData.username : '' %>"
            required>
    </div>
    <div class="form-group">
        <label class="form-label">Email Address</label>
        <input 
            type="email" 
            name="email"
            class="form-control" 
            placeholder="Enter your email" 
            value="<%= typeof formData !== 'undefined' && formData.email ? formData.email : '' %>"
            required>
    </div>
    <div class="form-group">
        <label class="form-label">Password</label>
        <input 
            type="password" 
            name="password"
            class="form-control" 
            placeholder="Create a password (min 6 characters)" 
            required>
    </div>
    <div class="form-group">
        <label class="form-label">University</label>
        <input 
            type="text" 
            name="university" 
            class="form-control" 
            placeholder="Enter your university name"
            value="<%= typeof formData !== 'undefined' && formData.university ? formData.university : '' %>"
            required>
        <small class="form-help-text">Examples: BUET, Dhaka University, North South University, BRAC University, etc.</small>
    </div>
    <button type="submit" class="btn btn--primary btn--full">Create Account</button>
    <div class="form-footer">
        Already have an account? <a href="/login" class="form-link">Login here</a>
    </div>
</form>